                </p>
                <div>
                    <a href="#" class="btn btn-primary">Shop Now</a>
                    <a href="#" class="btn btn-outline">Explore Brands</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Marquee Brand Section -->
    <section class="marquee-section">
        <div class="marquee-inner">
            <!-- First Set -->
            <div class="marquee-part">
                <div class="brand-logo"><img
                        src="https://cdn.shopify.com/s/files/1/0651/7535/5486/files/images_3.avif?v=1772422424"
                        alt="Brand Logo 1"></div>
                <div class="brand-logo"><img
                        src="https://cdn.shopify.com/s/files/1/0651/7535/5486/files/images_3_9ed6e77a-656c-4fbc-9418-986c8f0bfe47.avif?v=1772422423"
                        alt="Brand Logo 2"></div>
