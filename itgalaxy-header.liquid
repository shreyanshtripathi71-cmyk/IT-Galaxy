                            <img src="https://images.unsplash.com/photo-1517336714731-489689fd1ca8?auto=format&fit=crop&w=400&q=80" alt="Apple Spares" style="height: 140px; object-fit: cover; width: 100%; border-radius: 8px; margin-bottom: 15px;">
                            <h4 style="color: white; margin-bottom: 5px; font-size: 1.1rem; font-family: 'Poppins', sans-serif;">Apple Mac Components</h4>
                            <a href="#" style="color: var(--accent-blue); font-size: 0.85rem;">Shop Mac Parts →</a>
                        </div>
                    </div>
                    <div style="width: 1px; background: rgba(255,255,255,0.1); margin: 0 10px;"></div>
                    <div class="mega-menu-column" style="flex: 1; justify-content: flex-start; padding-top: 10px;">
                        <div class="mega-menu-title" style="margin-bottom: 15px;">More Categories</div>
                        <a href="#">Laptop Batteries</a>
                        <a href="#">Laptop Screens</a>
                        <a href="#">Power Adapters</a>
                        <a href="#">Cooling Fans</a>
                    </div>
                </div>
            `
        };

        let menuTimeout;

        navLinks.forEach(link => {
            link.addEventListener('mouseenter', (e) => {
                clearTimeout(menuTimeout);
                const menuId = link.getAttribute('data-menu');

                if (menuId === 'home') {
                    megaMenu.classList.remove('active');
                    if (window.scrollY < 50) {
                        headerContainer.style.background = 'var(--glass-bg)';
                        headerContainer.classList.remove('scrolled');
                    }
                    return;
                }

                if (menuData[menuId]) {
                    megaContent.innerHTML = menuData[menuId];
                } else {
                    megaContent.innerHTML = `
                        <div class="mega-menu-column">
                            <div class="mega-menu-title">Explore ${menuId.charAt(0).toUpperCase() + menuId.slice(1)}</div>
                            <a href="#">View All Deals</a>
                            <a href="#">New Arrivals</a>
                            <a href="#">Bestsellers</a>
                        </div>
                    `;
                }

                megaMenu.classList.add('active');
                headerContainer.classList.add('scrolled');
                headerContainer.style.background = 'rgba(5, 5, 5, 0.98)';
            });

            link.addEventListener('mouseleave', hideMenu);
        });

        megaMenu.addEventListener('mouseenter', () => clearTimeout(menuTimeout));
        megaMenu.addEventListener('mouseleave', hideMenu);

        function hideMenu() {
            menuTimeout = setTimeout(() => {
                megaMenu.classList.remove('active');
                if (window.scrollY < 50) {
                    headerContainer.style.background = 'var(--glass-bg)';
                    headerContainer.classList.remove('scrolled');
                }
            }, 100);
        }

        // Intersection Observer for Scroll Animations (Fade Up)
        const observerOptions = {
            root: null,
            rootMargin: '0px',
            threshold: 0.15
        };

        const observer = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    observer.unobserve(entry.target); // Run once
                }
            });
        }, observerOptions);

        document.querySelectorAll('.animate-on-scroll').forEach(element => {
            observer.observe(element);
        });

        // Horizontal Product Scroller Logic (Amazon Style)
        function scrollProducts(direction) {
            const scroller = document.getElementById('productScroller');
            const scrollAmount = Math.min(scroller.clientWidth * 0.8, 800); // Scroll 80% viewport, max 800px
            scroller.scrollBy({
                left: direction * scrollAmount,
                behavior: 'smooth'
            });
        }

        function scrollFlashDeals(direction) {
            const scroller = document.getElementById('flashScroller');
            const scrollAmount = Math.min(scroller.clientWidth * 0.8, 800); // Scroll 80% viewport, max 800px
            scroller.scrollBy({
                left: direction * scrollAmount,
                behavior: 'smooth'
            });
        }

        function scrollCategories(direction) {
            const scroller = document.getElementById('categoryScroller');
            const scrollAmount = Math.min(scroller.clientWidth * 0.8, 800);
            scroller.scrollBy({
                left: direction * scrollAmount,
                behavior: 'smooth'
            });
        }

        // Gas/Nebula Canvas Animation
        const gasCanvas = document.getElementById('gasCanvas');
        if (gasCanvas) {
            const gCtx = gasCanvas.getContext('2d');
            let gasParticles = [];
            const gasCount = window.innerWidth < 768 ? 40 : 100;

            function initGas() {
                gasCanvas.width = gasCanvas.offsetWidth;
                gasCanvas.height = gasCanvas.offsetHeight;
                gasParticles = [];
                for (let i = 0; i < gasCount; i++) {
                    gasParticles.push({
                        x: Math.random() * gasCanvas.width,
                        y: Math.random() * gasCanvas.height,
                        radius: Math.random() * 60 + 20,
                        vx: (Math.random() - 0.5) * 0.5,
                        vy: (Math.random() - 0.5) * 0.5,
                        life: Math.random(),
                        lifeSpeed: Math.random() * 0.01 + 0.005,
                        hue: Math.random() > 0.5 ? 192 : 347 // Blue or Red hue
                    });
                }
            }

            function animateGas() {
                gCtx.clearRect(0, 0, gasCanvas.width, gasCanvas.height);

                gasParticles.forEach(p => {
                    p.x += p.vx;
                    p.y += p.vy;
                    p.life += p.lifeSpeed;

                    if (p.x < -p.radius) p.x = gasCanvas.width + p.radius;
                    if (p.x > gasCanvas.width + p.radius) p.x = -p.radius;
                    if (p.y < -p.radius) p.y = gasCanvas.height + p.radius;
                    if (p.y > gasCanvas.height + p.radius) p.y = -p.radius;

                    const alpha = (Math.sin(p.life) * 0.5 + 0.5) * 0.15;

                    const gradient = gCtx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.radius);
                    if (p.hue === 192) {
                        gradient.addColorStop(0, `rgba(0, 210, 255, ${alpha})`); // Accent Blue
                    } else {
                        gradient.addColorStop(0, `rgba(255, 45, 85, ${alpha})`); // Accent Red
                    }
                    gradient.addColorStop(1, 'rgba(0, 0, 0, 0)');

                    gCtx.beginPath();
                    gCtx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
                    gCtx.fillStyle = gradient;
                    gCtx.fill();
                });

                requestAnimationFrame(animateGas);
            }

            window.addEventListener('resize', initGas);
            initGas();
            animateGas();
        }

        // Data Flow Canvas Animation (Binary Rain style horizontal flow)
        const dataCanvas = document.getElementById('dataCanvas');
        if (dataCanvas) {
            const dCtx = dataCanvas.getContext('2d');
            let dataStreams = [];
            const streamCount = window.innerWidth < 768 ? 20 : 50;

            function initData() {
                dataCanvas.width = dataCanvas.offsetWidth;
                dataCanvas.height = dataCanvas.offsetHeight;
                dataStreams = [];
                for (let i = 0; i < streamCount; i++) {
                    dataStreams.push({
                        y: Math.random() * dataCanvas.height,
                        x: Math.random() * dataCanvas.width,
                        length: Math.random() * 50 + 20,
                        speed: Math.random() * 5 + 2,
                        opacity: Math.random() * 0.5 + 0.1
                    });
                }
            }

            function animateData() {
                dCtx.fillStyle = 'rgba(0, 0, 0, 0.1)'; // Fade effect
                dCtx.fillRect(0, 0, dataCanvas.width, dataCanvas.height);

                dCtx.shadowBlur = 10;
                dCtx.shadowColor = '#00d2ff';
                dCtx.lineWidth = 2;

                dataStreams.forEach(stream => {
                    stream.x += stream.speed;
                    if (stream.x > dataCanvas.width + stream.length) {
                        stream.x = -stream.length;
                        stream.y = Math.random() * dataCanvas.height;
                    }

                    const gradient = dCtx.createLinearGradient(stream.x - stream.length, 0, stream.x, 0);
                    gradient.addColorStop(0, 'transparent');
                    gradient.addColorStop(1, `rgba(0, 210, 255, ${stream.opacity})`);

                    dCtx.beginPath();
                    dCtx.moveTo(stream.x - stream.length, stream.y);
                    dCtx.lineTo(stream.x, stream.y);
                    dCtx.strokeStyle = gradient;
                    dCtx.stroke();
                });

                requestAnimationFrame(animateData);
            }

            window.addEventListener('resize', initData);
            initData();
            animateData();
        }

        // Elite Collection 4-Tab Logic
        const eliteData = {
            monitor: {
                title: "Pro Display XDR",
                desc: "A masterful 6K Retina display with extreme dynamic range, staggering contrast ratio, and a hyper-wide viewing angle. Engineered for visual perfection.",
                img: "https://images.unsplash.com/photo-1527443154391-507e9dc6c5cc?auto=format&fit=crop&w=800&q=80",
                spec1Label: "Resolution",
                spec1Val: "6016 x 3384",
                spec2Label: "Brightness",
                spec2Val: "1600 nits"
            },
            headset: {
                title: "Studio ANC Wireless",
                desc: "Lossless high-fidelity audio paired with active noise cancellation. Dual-layer isolating earcups block the world so you can focus on the game.",
                img: "https://images.unsplash.com/photo-1618366712010-f4ae9c647dcb?auto=format&fit=crop&w=800&q=80",
                spec1Label: "Drivers",
                spec1Val: "50mm Neodymium",
                spec2Label: "Battery",
                spec2Val: "40 Hours"
            },
            webcam: {
                title: "Creator Cam 4K",
                desc: "Broadcast in stunning detail with a premium glass lens, smart auto-focus, and a massive Sony sensor that performs incredibly in low light.",
                img: "https://images.unsplash.com/photo-1590845947376-2638caa89309?auto=format&fit=crop&w=800&q=80",
                spec1Label: "Sensor",
                spec1Val: "1/1.8\" CMOS",
                spec2Label: "Framerate",
                spec2Val: "4K 60fps"
            },
            setup: {
                title: "The Ultimate Ecosystem",
                desc: "Why settle for parts when you can have a symphony? The Ultimate Setup combines our top-tier peripherals into one cohesive, instantly compatible battlestation.",
                img: "file:///Users/nikhil/.gemini/antigravity/brain/dde61182-e877-491c-8f07-1d9450c9bc27/featured_collection_teaser_1772531861091.png",
                spec1Label: "Optimization",
                spec1Val: "Pre-synced",
                spec2Label: "Lighting",
                spec2Val: "Aura Sync"
            }
        };

        function switchEliteTab(tabId) {
            // Update buttons
            ['monitor', 'headset', 'webcam', 'setup'].forEach(id => {
                document.getElementById('tab-' + id).className = 'btn btn-outline';
            });
            document.getElementById('tab-' + tabId).className = 'btn btn-primary';

            // Fade out
            const img = document.getElementById('eliteImage');
            const content = document.getElementById('eliteTextContainer');

            img.style.opacity = '0';
            content.style.opacity = '0';
            img.style.transform = 'scale(0.95)';

            setTimeout(() => {
                const data = eliteData[tabId];
                img.src = data.img;
                document.getElementById('eliteTitle').innerText = data.title;
                document.getElementById('eliteDesc').innerText = data.desc;

                document.getElementById('eliteSpecs').innerHTML = `
                    <div class="product-card" style="margin: 0; padding: 15px; background: rgba(255,255,255,0.03);">
                        <h4 style="font-size: 0.9rem; color: var(--accent-blue);">${data.spec1Label}</h4>
                        <p style="font-size: 1.2rem; font-weight: bold;">${data.spec1Val}</p>
                    </div>
                    <div class="product-card" style="margin: 0; padding: 15px; background: rgba(255,255,255,0.03);">
                            <h4 style="font-size: 0.9rem; color: var(--accent-blue);">${data.spec2Label}</h4>
                        <p style="font-size: 1.2rem; font-weight: bold;">${data.spec2Val}</p>
                    </div>
                `;

                // Fade in
                img.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
                img.style.opacity = '1';
                img.style.transform = 'scale(1)';
                content.style.opacity = '1';
            }, 300);
        }

        // Flash Deals Countdown Timer
        function updateTimer() {
            const hoursVal = document.querySelectorAll('.countdown-val')[0];
            const minsVal = document.querySelectorAll('.countdown-val')[1];
            const secsVal = document.querySelectorAll('.countdown-val')[2];

            if (!hoursVal) return;

            let h = parseInt(hoursVal.innerText);
            let m = parseInt(minsVal.innerText);
            let s = parseInt(secsVal.innerText);

            s--;
            if (s < 0) { s = 59; m--; }
            if (m < 0) { m = 59; h--; }
            if (h < 0) { h = 23; }

            hoursVal.innerText = h.toString().padStart(2, '0');
            minsVal.innerText = m.toString().padStart(2, '0');
            secsVal.innerText = s.toString().padStart(2, '0');
        }

        setInterval(updateTimer, 1000);
        // Category Marquee SCROLLER Logic
        function scrollCategories(direction) {
            const scroller = document.getElementById('categoryScroller');
            const scrollAmount = 420; // Width of card + gap
            scroller.scrollBy({
                left: direction * scrollAmount,
                behavior: 'smooth'
            });
        }

        // Auto-scroll logic for Category Marquee
        let categoryScrollerDOM = document.getElementById('categoryScroller');
        let categoryScrollInterval;

        function startCategoryMarquee() {
            categoryScrollInterval = setInterval(() => {
                // If it reached the end, scroll back to beginning
                if (categoryScrollerDOM.scrollLeft + categoryScrollerDOM.clientWidth >= categoryScrollerDOM.scrollWidth - 10) {
                    categoryScrollerDOM.scrollTo({ left: 0, behavior: 'smooth' });
                } else {
                    categoryScrollerDOM.scrollBy({ left: 320, behavior: 'smooth' });
                }
            }, 3000); // scrolls every 3 seconds
        }

        function stopCategoryMarquee() {
            clearInterval(categoryScrollInterval);
        }

        startCategoryMarquee(); // Start on load

        // Pause marquee if the user hovers over it
        categoryScrollerDOM.addEventListener('mouseenter', stopCategoryMarquee);
        // Interactive Keyboard Comparison Slider
        const comparisonContainer = document.getElementById('keyboardComparison');
        const comparisonOverlay = document.getElementById('comparisonOverlay');
        const comparisonSlider = document.getElementById('comparisonSlider');

        if (comparisonContainer) {
            comparisonContainer.addEventListener('mousemove', (e) => {
                const rect = comparisonContainer.getBoundingClientRect();
                let position = ((e.clientX - rect.left) / rect.width) * 100;

                // Restrict bounds
                if (position < 2) position = 2;
                if (position > 98) position = 98;

                comparisonSlider.style.left = `${position}%`;
                comparisonOverlay.style.width = `${position}%`;
            });

            // Touch support
            comparisonContainer.addEventListener('touchmove', (e) => {
                const rect = comparisonContainer.getBoundingClientRect();
                const touch = e.touches[0];
                let position = ((touch.clientX - rect.left) / rect.width) * 100;

                if (position < 2) position = 2;
                if (position > 98) position = 98;

                comparisonSlider.style.left = `${position}%`;
                comparisonOverlay.style.width = `${position}%`;
            });
        }

        categoryScrollerDOM.addEventListener('mouseleave', startCategoryMarquee);



        // Custom Cursor Logic
        const cursor = document.getElementById('cursor');
        const dot = document.getElementById('cursorDot');

        document.addEventListener('mousemove', (e) => {
            cursor.style.left = e.clientX + 'px';
            cursor.style.top = e.clientY + 'px';
            dot.style.left = e.clientX + 'px';
            dot.style.top = e.clientY + 'px';
        });

        document.querySelectorAll('a, button, .product-card, .bento-card, .brand-logo').forEach(el => {
            el.addEventListener('mouseenter', () => cursor.classList.add('hover'));
            el.addEventListener('mouseleave', () => cursor.classList.remove('hover'));
        });

        // Neural Network Canvas Animation (Hyper)
        if (canvas) {
            const ctx = canvas.getContext('2d');
            let particles = [];
            const particleCount = 80;

            function initParticles() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
                particles = [];
                for (let i = 0; i < particleCount; i++) {
                    particles.push({
                        x: Math.random() * canvas.width,
                        y: Math.random() * canvas.height,
                        vx: (Math.random() - 0.5) * 1.5,
                        vy: (Math.random() - 0.5) * 1.5,
                        size: Math.random() * 3
                    });
                }
            }

            function animateParticles() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                ctx.fillStyle = '#00d2ff';
                ctx.strokeStyle = 'rgba(0, 210, 255, 0.15)';

                particles.forEach((p, i) => {
                    p.x += p.vx;
                    p.y += p.vy;
                    if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
                    if (p.y < 0 || p.y > canvas.height) p.vy *= -1;

                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
                    ctx.fill();

                    for (let j = i + 1; j < particles.length; j++) {
                        const p2 = particles[j];
                        const dist = Math.sqrt((p.x - p2.x) ** 2 + (p.y - p2.y) ** 2);
                        if (dist < 150) {
                            ctx.lineWidth = (1 - dist / 150) * 1.5;
                            ctx.beginPath();
                            ctx.moveTo(p.x, p.y);
                            ctx.lineTo(p2.x, p2.y);
                            ctx.stroke();
                        }
                    }
                });
                requestAnimationFrame(animateParticles);
            }

            window.addEventListener('resize', initParticles);
            initParticles();
            animateParticles();
        }

        // Parabolic Speed Scroll Logic
        let lastScroll = 0;
        const skewLimit = 10;
        window.addEventListener('scroll', () => {
            const scroll = window.pageYOffset;
            const diff = scroll - lastScroll;
            const skew = Math.min(Math.max(diff * 0.1, -skewLimit), skewLimit);

            document.querySelectorAll('section:not(.hero), .product-card').forEach(el => {
                el.style.transform = `skewY(${skew}deg)`;
            });

            lastScroll = scroll;

            const grid = document.getElementById('gridBg');
            if (grid) grid.style.transform = `rotateX(60deg) translateY(${-200 + (scroll * 0.2)}px)`;

            const headings = document.querySelectorAll('h2');
            headings.forEach(h => {
                const rect = h.getBoundingClientRect();
                const visible = rect.top < window.innerHeight && rect.bottom > 0;
                if (visible) {
                    const factor = (window.innerHeight - rect.top) / window.innerHeight;
                    h.style.letterSpacing = `${(1 - factor) * 10}px`;
                }
            });
        });

        // Spotlight and Cursor Magnetic Physics
        document.addEventListener('mousemove', (e) => {
            const spotlight = document.getElementById('spotlight');
            if (spotlight) {
                spotlight.style.setProperty('--x', e.clientX + 'px');
                spotlight.style.setProperty('--y', e.clientY + 'px');
            }

            document.querySelectorAll('.btn, .nav-links a, .logo').forEach(el => {
                const rect = el.getBoundingClientRect();
                const x = e.clientX - rect.left - rect.width / 2;
                const y = e.clientY - rect.top - rect.height / 2;
                const distance = Math.sqrt(x * x + y * y);

                if (distance < 100) {
                    el.style.transform = `translate(${x * 0.3}px, ${y * 0.3}px)`;
                } else {
                    el.style.transform = 'translate(0, 0)';
                }
            });
        });

        // Advanced 3D Tilt with Lighting Internal Glow
        document.querySelectorAll('.product-card, .bento-card, .wide-cat-card').forEach(card => {
            card.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                const xc = rect.width / 2;
                const yc = rect.height / 2;
                const dx = x - xc;
                const dy = y - yc;

                card.style.transform = `perspective(1500px) rotateY(${dx / 12}deg) rotateX(${-dy / 12}deg) translateY(-8px)`;
                card.style.boxShadow = `${-dx / 10}px ${-dy / 10}px 50px rgba(0, 210, 255, 0.2)`;
                card.style.backgroundImage = `radial-gradient(circle at ${x}px ${y}px, rgba(255,255,255,0.08) 0%, transparent 60%)`;
            });

            card.addEventListener('mouseleave', () => {
                card.style.transform = 'perspective(1500px) rotateY(0deg) rotateX(0deg) translateY(0px)';
                card.style.boxShadow = 'none';
                card.style.backgroundImage = 'none';
            });
        });

        // Floating Data Fragments
        function createFragments() {
            const container = document.body;
            for (let i = 0; i < 20; i++) {
                const fragment = document.createElement('div');
                fragment.className = 'data-fragment';
                fragment.style.left = Math.random() * 100 + 'vw';
                fragment.style.top = Math.random() * 100 + 'vh';
                fragment.style.animation = `float ${3 + Math.random() * 5}s infinite ease-in-out`;
                container.appendChild(fragment);
            }
        }
        createFragments();
    </script>
</body>

</html>