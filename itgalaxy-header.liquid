<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IT Galaxy | Premium Electronics</title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Poppins:wght@400;500;700;800&display=swap"
        rel="stylesheet">
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">


    <style>
        :root {
            --bg-primary: #020202;
            --bg-secondary: #080808;
            --bg-card: rgba(18, 18, 18, 0.4);
            --text-main: #ffffff;
            --text-muted: #888888;
            --accent-red: #ff2d55;
            --accent-red-glow: rgba(255, 45, 85, 0.3);
            --accent-blue: #00d2ff;
            --accent-blue-glow: rgba(0, 210, 255, 0.2);
            --border-color: rgba(255, 255, 255, 0.08);
            --glass-bg: rgba(5, 5, 5, 0.6);
            --glass-border: rgba(255, 255, 255, 0.03);
            --transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
            --font-main: 'Inter', sans-serif;
            --font-heading: 'Poppins', sans-serif;
        }

        /* Custom Cursor Style */
        .custom-cursor {
            width: 20px;
            height: 20px;
            border: 2px solid var(--accent-blue);
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 9999;
            transition: transform 0.1s ease, background 0.3s ease, border-width 0.3s ease, border-color 0.3s ease;
            mix-blend-mode: difference;
        }

        .custom-cursor.hover {
            transform: scale(3);
            background: rgba(255, 255, 255, 0.2);
            border-width: 0;
        }

        .cursor-dot {
            width: 4px;
            height: 4px;
            background: var(--accent-red);
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 9999;
        }

        /* Reset & BaseStyles */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-primary);
            color: var(--text-main);
            overflow-x: hidden;
            line-height: 1.6;
        }

        h1,
        h2,
        h3,
        h4,
        h5,
        h6 {
            font-family: 'Poppins', sans-serif;
            font-weight: 700;
            line-height: 1.2;
        }

        a {
            color: var(--text-main);
            text-decoration: none;
            transition: var(--transition);
        }

        /* Utility Classes - Full Edge-to-Edge Free Flow */
        .container {
            width: 100%;
            max-width: none;
            margin: 0;
            padding: 0 3%;
            /* Minimal padding just to keep text off the exact monitor glass edges */
        }

        .section-padding {
            padding: 100px 0;
        }

        .text-gradient {
            background: linear-gradient(90deg, var(--accent-red), var(--accent-blue));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Animations */
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes float {
            0% {
                transform: translateY(0px);
            }

            50% {
                transform: translateY(-20px);
            }

            100% {
                transform: translateY(0px);
            }
        }

        @keyframes marquee {
            0% {
                transform: translateX(0);
            }

            100% {
                transform: translateX(-50%);
            }
        }

        @keyframes pulseGlow {
            0% {
                box-shadow: 0 0 20px var(--accent-red-glow);
            }

            50% {
                box-shadow: 0 0 40px var(--accent-blue-glow);
            }

            100% {
                box-shadow: 0 0 20px var(--accent-red-glow);
            }
        }

        .animate-on-scroll {
            opacity: 0;
            transform: translateY(60px) scale(0.95) rotateX(10deg);
            transition: opacity 1s cubic-bezier(0.23, 1, 0.32, 1), transform 1s cubic-bezier(0.23, 1, 0.32, 1);
            perspective: 1000px;
        }

        .animate-on-scroll.visible {
            opacity: 1;
            transform: translateY(0) scale(1) rotateX(0deg);
        }

        /* Parabolic Backdrop */
        .noise-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: url('https://grainy-gradients.vercel.app/noise.svg');
            opacity: 0.04;
            pointer-events: none;
            z-index: 9998;
        }

        .perspective-grid {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image:
                linear-gradient(rgba(0, 210, 255, 0.05) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 210, 255, 0.05) 1px, transparent 1px);
            background-size: 100px 100px;
            perspective: 500px;
            transform: rotateX(60deg) translateY(-200px);
            opacity: 0.1;
            pointer-events: none;
            z-index: -1;
            transition: transform 0.1s ease-out;
        }

        .spotlight {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at var(--x) var(--y), rgba(0, 210, 255, 0.15) 0%, transparent 40%);
            pointer-events: none;
            z-index: 1;
        }

        .glitch-text {
            position: relative;
            display: inline-block;
        }

        .glitch-text:hover::before,
        .glitch-text:hover::after {
            content: attr(data-text);
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: var(--bg-primary);
        }

        .glitch-text:hover::before {
            left: 2px;
            text-shadow: -2px 0 var(--accent-blue);
            clip: rect(44px, 450px, 56px, 0);
            animation: glitch-anim 5s infinite linear alternate-reverse;
        }

        .glitch-text:hover::after {
            left: -2px;
            text-shadow: -2px 0 var(--accent-red);
            clip: rect(44px, 450px, 56px, 0);
            animation: glitch-anim2 5s infinite linear alternate-reverse;
        }

        @keyframes glitch-anim {
            0% {
                clip: rect(31px, 9999px, 94px, 0);
            }

            100% {
                clip: rect(98px, 9999px, 5px, 0);
            }
        }

        @keyframes glitch-anim2 {
            0% {
                clip: rect(65px, 9999px, 100px, 0);
            }

            100% {
                clip: rect(8px, 9999px, 68px, 0);
            }
        }

        .data-fragment {
            position: absolute;
            width: 2px;
            height: 20px;
            background: var(--accent-blue);
            opacity: 0.3;
            pointer-events: none;
            z-index: 10;
        }

        /* Header / Navbar */
        header {
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
            background: var(--glass-bg);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--glass-border);
            transition: var(--transition);
        }

        header.scrolled {
            padding: 5px 0;
            background: rgba(5, 5, 5, 0.9);
            box-shadow: 0 5px 30px rgba(0, 0, 0, 0.5);
        }

        .nav-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 100px;
            /* Made header bigger */
            width: 100%;
            padding: 0 4%;
            transition: var(--transition);
        }

        .logo {
            font-size: 2.2rem;
            /* Larger Logo */
            font-family: 'Poppins', sans-serif;
            font-weight: 800;
            letter-spacing: -1px;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: var(--transition);
        }

        .logo:hover {
            transform: scale(1.05);
            text-shadow: 0 0 20px rgba(255, 255, 255, 0.4);
        }

        .logo i {
            color: var(--accent-blue);
            font-size: 2rem;
            transition: var(--transition);
            text-shadow: 0 0 15px var(--accent-blue-glow);
        }

        .logo:hover i {
            transform: rotate(15deg);
            text-shadow: 0 0 25px var(--accent-blue);
        }

        .nav-links {
            display: flex;
            gap: 35px;
            /* More spacing */
            list-style: none;
        }

        .nav-links a {
            font-size: 1.15rem;
            /* Larger nav links */
            font-weight: 500;
            position: relative;
            padding-bottom: 5px;
            transition: color 0.3s ease;
        }

        .nav-links a:hover {
            color: var(--text-main);
            text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--accent-red), var(--accent-blue));
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            border-radius: 2px;
        }

        .nav-links a:hover::after {
            width: 100%;
            box-shadow: 0 0 15px var(--accent-blue-glow);
        }

        .nav-icons {
            display: flex;
            gap: 25px;
            /* Larger icon spacing */
            align-items: center;
            font-size: 1.2rem;
            /* Larger icons */
        }

        .nav-icons i {
            font-size: 1.2rem;
            cursor: pointer;
            transition: var(--transition);
        }

        .nav-icons i:hover {
            color: var(--accent-red);
            transform: scale(1.1);
        }

        .cart-icon {
            position: relative;
        }

        .cart-badge {
            position: absolute;
            top: -8px;
            right: -10px;
            background: var(--accent-red);
            color: white;
            font-size: 0.7rem;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-weight: bold;
        }

        .mega-menu {
            position: absolute;
            top: 100%;
            left: 0;
            width: 100%;
            background: rgba(5, 5, 5, 0.98);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border-color);
            padding: 40px 5%;
            display: flex;
            justify-content: center;
            opacity: 0;
            visibility: hidden;
            transform: scaleY(0);
            transform-origin: top;
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            z-index: 999;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.8);
        }

        /* Clouds Marquee Effect */
        .header-clouds,
        .header-clouds-2 {
            position: absolute;
            left: 0;
            width: 200%;
            pointer-events: none;
            z-index: -1;
        }

        .header-clouds {
            bottom: -150px;
            height: 200px;
            background: url('https://raw.githubusercontent.com/danielstuart14/CSS_FOG_ANIMATION/master/fog1.png') repeat-x;
            background-size: auto 100%;
            opacity: 0.5;
            animation: marqueeClouds 60s linear infinite;
            /* Added blueish lighting matching the dark neon theme */
            filter: invert(1) brightness(0.8) sepia(1) hue-rotate(180deg) saturate(2);
            -webkit-mask-image: linear-gradient(to bottom, black 10%, transparent 100%);
            mask-image: linear-gradient(to bottom, black 10%, transparent 100%);
        }

        .header-clouds-2 {
            bottom: -100px;
            height: 150px;
            background: url('https://raw.githubusercontent.com/danielstuart14/CSS_FOG_ANIMATION/master/fog2.png') repeat-x;
            background-size: auto 100%;
            opacity: 0.4;
            animation: marqueeClouds 45s linear infinite reverse;
            filter: invert(1) brightness(0.9) sepia(1) hue-rotate(180deg) saturate(2);
            -webkit-mask-image: linear-gradient(to bottom, black 10%, transparent 100%);
            mask-image: linear-gradient(to bottom, black 10%, transparent 100%);
        }

        @keyframes marqueeClouds {
            0% {
                transform: translateX(0);
            }

            100% {
                transform: translateX(-50%);
            }
        }

        .mega-menu.active {
            opacity: 1;
            visibility: visible;
            transform: scaleY(1);
        }

        .mega-menu-content {
            display: flex;
            justify-content: center;
            gap: 60px;
            width: 100%;
            max-width: 1200px;
            opacity: 0;
            transform: translateY(-20px);
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            transition-delay: 0.1s;
        }

        .mega-menu.active .mega-menu-content {
            opacity: 1;
            transform: translateY(0);
        }

        .mega-menu-column {
            display: flex;
            flex-direction: column;
            gap: 15px;
            min-width: 150px;
        }

        .mega-menu-title {
            font-size: 1.1rem;
            color: var(--text-main);
            margin-bottom: 10px;
            font-family: 'Poppins', sans-serif;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .mega-menu-column a {
            color: var(--text-muted);
            font-size: 0.95rem;
            transition: var(--transition);
        }

        .mega-menu-column a:hover {
            color: var(--accent-blue);
            transform: translateX(5px);
        }

        .mega-menu-promo {
            display: flex;
            flex-direction: column;
            align-items: center;
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 20px;
            max-width: 250px;
            margin-left: 30px;
        }

        .mega-menu-promo img {
            width: 100%;
            border-radius: 8px;
            margin-bottom: 15px;
        }

        /* Hero Section */
        .hero {
            position: relative;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding-top: 80px;
            overflow: hidden;
            text-align: center;
        }

        .hero-video {
            position: absolute;
            top: 50%;
            left: 50%;
            min-width: 100%;
            min-height: 100%;
            width: auto;
            height: auto;
            transform: translateX(-50%) translateY(-50%);
            z-index: -2;
            object-fit: cover;
            filter: brightness(0.7) contrast(1.1);
        }

        @keyframes slowPan {
            0% {
                transform: scale(1) translate(0, 0);
            }

            100% {
                transform: scale(1.15) translate(-2%, 2%);
            }
        }

        .hero-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(to bottom, rgba(5, 5, 5, 0.4) 0%, rgba(5, 5, 5, 1) 100%);
            z-index: -1;
        }

        .hero-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            z-index: 2;
            width: 100%;
            max-width: 900px;
        }

        .hero-text h1 {
            font-size: 5.5rem;
            margin-bottom: 20px;
            animation: fadeIn 1s ease-out;
            text-shadow: 0 5px 25px rgba(0, 0, 0, 0.9);
        }

        .hero-text p {
            font-size: 1.3rem;
            color: var(--text-main);
            margin-bottom: 40px;
            max-width: 700px;
            margin-left: auto;
            margin-right: auto;
            animation: fadeIn 1.2s ease-out;
            text-shadow: 0 2px 15px rgba(0, 0, 0, 0.9);
        }

        .btn {
            display: inline-block;
            padding: 15px 40px;
            border-radius: 30px;
            font-weight: 600;
            font-family: 'Poppins', sans-serif;
            text-transform: uppercase;
            letter-spacing: 1px;
            position: relative;
            overflow: hidden;
            z-index: 1;
            border: none;
            cursor: pointer;
            transition: var(--transition);
        }

        .btn-primary {
            background: linear-gradient(45deg, var(--accent-red), #ff007f);
            color: white;
            box-shadow: 0 10px 30px var(--accent-red-glow);
            animation: fadeIn 1.4s ease-out;
        }

        .btn-primary::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: all 0.6s;
            z-index: -1;
        }

        .btn-primary:hover::before {
            left: 100%;
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(255, 51, 102, 0.6);
        }

        .btn-outline {
            background: transparent;
            border: 2px solid var(--border-color);
            color: var(--text-main);
            margin-left: 20px;
        }

        .btn-outline:hover {
            border-color: var(--accent-blue);
            background: rgba(0, 240, 255, 0.05);
            box-shadow: 0 0 20px var(--accent-blue-glow);
        }

        .hero-image {
            position: relative;
            animation: fadeIn 1.5s ease-out;
        }

        .hero-image img {
            width: 100%;
            max-width: 650px;
            height: auto;
            object-fit: contain;
            animation: float 6s ease-in-out infinite;
            filter: drop-shadow(0 30px 40px rgba(0, 0, 0, 0.8));
        }

        /* Marquee Brands - Infinite Loop */
        .marquee-section {
            background: transparent;
            padding: 0;
            margin-top: -50px;
            /* Pull the marquee tighter towards the hero section */
            margin-bottom: 20px;
            overflow: hidden;
            position: relative;
            /* Fades out the left and right edges so logos smoothly appear/disappear */
            -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
            mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
            z-index: 5;
        }

        .marquee-inner {
            display: flex;
            width: max-content;
            animation: scrollMarquee 35s linear infinite;
        }

        .marquee-inner:hover {
            animation-play-state: paused;
        }

        .marquee-part {
            display: flex;
        }

        @keyframes scrollMarquee {
            0% {
                transform: translateX(0);
            }

            100% {
                transform: translateX(-50%);
            }

            /* Scrolls exactly one half, seamless loop */
        }

        .brand-logo {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 220px;
            /* Shrunk logos as requested */
            height: 100px;
            margin: 0 10px;
            flex-shrink: 0;
            position: relative;
            transform-style: preserve-3d;
            perspective: 1000px;
        }

        .brand-logo img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            /* Ultra-clean, subtle metallic shadow, slightly muted color for premium feel */
            filter: drop-shadow(0 10px 15px rgba(0, 0, 0, 0.5)) grayscale(30%) opacity(0.8);
            transition: all 0.8s cubic-bezier(0.25, 1, 0.5, 1);
            /* High-end ultra-smooth Apple-style ease */
            transform: translateZ(0) scale(0.95);
            image-rendering: high-quality;
            image-rendering: -webkit-optimize-contrast;
        }

        .brand-logo:hover img {
            /* Elegant, measured 3D lift without crazy rotation/skew */
            transform: translateY(-12px) scale(1.08) translateZ(30px);
            /* Clean white/silver premium glow, full color, high opacity */
            filter: drop-shadow(0 25px 30px rgba(0, 0, 0, 0.8)) drop-shadow(0 0 25px rgba(255, 255, 255, 0.15)) grayscale(0%) opacity(1);
            z-index: 10;
        }

        /* Categories Section - Futuristic Cards */
        .section-header {
            text-align: center;
            margin-bottom: 70px;
            position: relative;
            padding: 0 4%;
            /* Ensure text has breathing room when section is edge-to-edge */
        }

        .section-header h2 {
            font-size: 3rem;
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 2px;
            text-shadow: 0 0 20px var(--accent-blue-glow);
            display: inline-block;
            position: relative;
        }

        .section-header h2::after {
            content: '';
            position: absolute;
            left: 50%;
            bottom: -10px;
            transform: translateX(-50%);
            width: 80px;
            height: 4px;
            background: linear-gradient(90deg, transparent, var(--accent-blue), transparent);
            border-radius: 2px;
            box-shadow: 0 0 10px var(--accent-blue-glow);
        }

        .section-header p {
            color: var(--text-muted);
            font-size: 1.2rem;
            letter-spacing: 1px;
            margin-top: 15px;
        }

        .category-scroller-wrapper {
            position: relative;
            margin-top: 20px;
        }

        .category-scroller {
            display: flex;
            gap: 40px;
            overflow-x: auto;
            scroll-behavior: smooth;
            scrollbar-width: none;
            /* Firefox */
            padding: 20px 4% 20px 4%;
            /* Allow breakout but align start position */
            perspective: 1200px;
        }

        .category-scroller::-webkit-scrollbar {
            display: none;
            /* Chrome/Safari */
        }

        .category-card {
            position: relative;
            flex: 0 0 auto;
            width: 380px;
            /* Fixed width for horizontal scrolling */
            border-radius: 20px;
            overflow: hidden;
            height: 450px;
            background: rgba(10, 10, 15, 0.6);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(0, 240, 255, 0.15);
            transition: all 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            cursor: pointer;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6), inset 0 0 20px rgba(0, 240, 255, 0.05);
            transform-style: preserve-3d;
        }

        .category-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(to top, rgba(0, 5, 10, 0.95) 0%, rgba(0, 240, 255, 0.1) 100%);
            z-index: 1;
            transition: opacity 0.5s ease;
        }

        .category-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.8s ease;
            opacity: 0.8;
            filter: grayscale(20%) contrast(1.2);
        }

        .category-card:hover {
            transform: translateY(-20px) rotateX(10deg);
            border-color: var(--accent-blue);
            box-shadow: 0 30px 60px rgba(0, 240, 255, 0.3), inset 0 0 30px rgba(0, 240, 255, 0.2);
        }

        .category-card:hover::before {
            background: linear-gradient(to top, rgba(0, 0, 0, 0.9) 0%, transparent 100%);
        }

        .category-card:hover img {
            transform: scale(1.15);
            opacity: 1;
            filter: grayscale(0%) contrast(1.2);
        }

        .category-info {
            position: absolute;
            bottom: 40px;
            left: 40px;
            z-index: 2;
            transform: translateZ(40px);
            /* Pushes text forward in 3D */
            transition: all 0.5s ease;
        }

        .category-info h3 {
            font-size: 2.2rem;
            margin-bottom: 10px;
            transition: var(--transition);
            text-transform: uppercase;
            letter-spacing: 2px;
            text-shadow: 0 5px 15px rgba(0, 0, 0, 0.8);
        }

        .category-info p {
            color: var(--accent-blue);
            font-size: 1.1rem;
            text-transform: uppercase;
            letter-spacing: 3px;
            font-weight: 600;
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            text-shadow: 0 0 10px var(--accent-blue-glow);
        }

        .category-card:hover .category-info p {
            opacity: 1;
            transform: translateY(0);
        }

        /* Amazon Style Horizontal Product Scroller */
        .product-scroller-wrapper {
            position: relative;
        }

        .product-scroller {
            display: flex;
            gap: 25px;
            overflow-x: auto;
            padding: 20px 4% 40px 4%;
            /* Align start position, free flow everything else */
            scroll-behavior: smooth;
            scrollbar-width: none;
            /* Firefox */
        }

        .product-scroller::-webkit-scrollbar {
            display: none;
            /* Chrome/Safari */
        }

        .scroll-btn {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: var(--glass-bg);
            border: 1px solid var(--border-color);
            color: white;
            font-size: 1.2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 10;
            backdrop-filter: blur(5px);
            transition: var(--transition);
        }

        .scroll-btn:hover {
            background: var(--accent-red);
            border-color: var(--accent-red);
        }

        .scroll-left {
            left: -25px;
        }

        .scroll-right {
            right: -25px;
        }

        .product-card {
            min-width: 280px;
            background: var(--bg-card);
            border-radius: 16px;
            padding: 20px;
            border: 1px solid var(--border-color);
            transition: var(--transition);
            display: flex;
            flex-direction: column;
            position: relative;
        }

        .product-card:hover {
            border-color: var(--accent-red);
            box-shadow: 0 10px 30px var(--accent-red-glow);
            transform: translateY(-5px);
        }

        .product-badge {
            position: absolute;
            top: 20px;
            left: 20px;
            background: var(--accent-red);
            font-size: 0.75rem;
            font-weight: bold;
            padding: 4px 10px;
            border-radius: 20px;
            z-index: 2;
        }

        .product-img {
            height: 200px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
            position: relative;
            overflow: hidden;
        }

        .product-img img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
            transition: all 0.5s;
        }

        .product-card:hover .product-img img {
            transform: scale(1.1) rotate(-5deg);
        }

        .product-action {
            position: absolute;
            bottom: -50px;
            left: 0;
            width: 100%;
            display: flex;
            justify-content: center;
            gap: 10px;
            opacity: 0;
            transition: var(--transition);
        }

        .product-card:hover .product-action {
            bottom: 10px;
            opacity: 1;
        }

        .action-btn {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.1);
            color: white;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            backdrop-filter: blur(5px);
            transition: var(--transition);
        }

        .action-btn:hover {
            background: var(--accent-blue);
            color: black;
        }

        .product-category {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-bottom: 5px;
        }

        .product-title {
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 15px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .product-bottom {
            margin-top: auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .product-price {
            font-size: 1.25rem;
            font-weight: 700;
            font-family: 'Poppins', sans-serif;
            color: var(--accent-blue);
        }

        .product-price del {
            font-size: 0.9rem;
            color: var(--text-muted);
            margin-right: 8px;
        }

        /* Call to Action Banner */
        .cta-section {
            padding: 80px 0;
            background: linear-gradient(135deg, rgba(20, 20, 20, 1) 0%, rgba(5, 5, 5, 1) 100%);
            border-top: 1px solid var(--border-color);
            border-bottom: 1px solid var(--border-color);
            position: relative;
            overflow: hidden;
        }

        .cta-container {
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: relative;
            z-index: 2;
        }

        .cta-content {
            flex: 1;
            max-width: 600px;
        }

        .cta-content h2 {
            font-size: 3rem;
            margin-bottom: 20px;
        }

        .cta-content p {
            font-size: 1.2rem;
            color: var(--text-muted);
            margin-bottom: 30px;
        }

        .cta-image {
            flex: 1;
            text-align: right;
        }

        .cta-image img {
            max-width: 80%;
            filter: drop-shadow(0 20px 30px rgba(0, 240, 255, 0.4));
            animation: float 5s infinite;
        }

        /* Footer */
        footer {
            background: #000;
            padding: 80px 0 30px 0;
            border-top: 1px solid var(--border-color);
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1.5fr;
            gap: 50px;
            margin-bottom: 50px;
        }

        .footer-about p {
            color: var(--text-muted);
            margin-top: 20px;
            margin-bottom: 20px;
        }

        .social-icons {
            display: flex;
            gap: 15px;
        }

        .social-icons a {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--bg-card);
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid var(--border-color);
        }

        .social-icons a:hover {
            background: var(--accent-red);
            border-color: var(--accent-red);
            transform: translateY(-3px);
        }

        .footer-links h4 {
            font-size: 1.2rem;
            margin-bottom: 20px;
        }

        .footer-links ul {
            list-style: none;
        }

        .footer-links li {
            margin-bottom: 12px;
        }

        .footer-links a {
            color: var(--text-muted);
        }

        .footer-links a:hover {
            color: var(--accent-blue);
            padding-left: 5px;
        }

        .newsletter input {
            width: 100%;
            padding: 15px 20px;
            border-radius: 8px;
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            color: white;
            margin-bottom: 15px;
            font-family: inherit;
        }

        .newsletter input:focus {
            outline: none;
            border-color: var(--accent-blue);
        }

        .newsletter button {
            width: 100%;
            padding: 15px;
            border-radius: 8px;
            background: var(--accent-blue);
            color: black;
            border: none;
            font-weight: 700;
            cursor: pointer;
            transition: var(--transition);
        }

        .newsletter button:hover {
            background: white;
            box-shadow: 0 0 20px var(--accent-blue-glow);
        }

        .footer-bottom {
            text-align: center;
            padding-top: 30px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            color: var(--text-muted);
            font-size: 0.9rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .payment-icons {
            display: flex;
            gap: 15px;
            font-size: 1.5rem;
            opacity: 0.7;
        }

        /* Responsive Design */
        @media (max-width: 1024px) {
            .hero-content {
                grid-template-columns: 1fr;
                text-align: center;
                gap: 30px;
            }

            .hero-text p {
                margin: 0 auto 30px auto;
            }

            .btn-outline {
                margin-left: 10px;
                margin-top: 15px;
            }

            .cta-container {
                flex-direction: column;
                text-align: center;
                gap: 40px;
            }

            .footer-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        @media (max-width: 768px) {
            .nav-links {
                display: none;
                /* In a real app, add a hamburger menu */
            }

            .hero-text h1 {
                font-size: 3rem;
            }

            .footer-grid {
                grid-template-columns: 1fr;
            }

            .footer-bottom {
                flex-direction: column;
                gap: 20px;
            }
        }

        /* Flash Deals Section */
        .flash-deals-section {
            background: linear-gradient(to right, #0a0a0a, #150a15);
            padding: 80px 0;
            position: relative;
            overflow: hidden;
        }

        .flash-deals-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 50px;
            flex-wrap: wrap;
            gap: 20px;
        }

        .countdown-timer {
            display: flex;
            gap: 15px;
            background: rgba(255, 51, 102, 0.1);
            padding: 10px 25px;
            border-radius: 50px;
            border: 1px solid rgba(255, 51, 102, 0.3);
            box-shadow: 0 0 20px rgba(255, 51, 102, 0.2);
        }

        .countdown-item {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .countdown-val {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--accent-red);
        }

        .countdown-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            color: var(--text-muted);
        }

        /* Split Section Layout (Networking, Featured Collection) */
        .split-section {
            display: flex;
            align-items: center;
            gap: 60px;
            margin-bottom: 100px;
        }

        .split-image {
            flex: 1;
            position: relative;
            border-radius: 20px;
            overflow: hidden;
            min-height: 500px;
        }

        .split-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: var(--transition);
        }

        .split-image:hover img {
            transform: scale(1.05);
        }

        .split-content {
            flex: 1;
        }

        .split-section.reverse {
            flex-direction: row-reverse;
        }

        /* Wide Categories Card Grid */
        .wide-categories-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
            margin-top: 50px;
        }

        .wide-cat-card {
            position: relative;
            height: 400px;
            border-radius: 20px;
            overflow: hidden;
            cursor: pointer;
        }

        .wide-cat-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: all 0.7s ease;
        }

        .wide-cat-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(0, 0, 0, 0.9) 0%, transparent 60%);
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            padding: 40px;
            transition: all 0.5s ease;
        }

        .wide-cat-card:hover img {
            transform: scale(1.1);
        }

        .wide-cat-card:hover .wide-cat-overlay {
            background: linear-gradient(to top, var(--accent-blue-glow) 0%, transparent 80%);
        }

        .wide-cat-card h3 {
            font-size: 2rem;
            margin-bottom: 10px;
        }

        /* Custom Icon Marquee (at end) */
        .icon-marquee-section {
            padding: 60px 0;
            background: #050505;
            border-top: 1px solid var(--border-color);
            border-bottom: 1px solid var(--border-color);
            overflow: hidden;
        }

        .icon-marquee-inner {
            display: flex;
            gap: 80px;
            animation: scrollIcons 25s linear infinite;
            width: max-content;
        }

        .icon-item {
            font-size: 2.8rem;
            color: rgba(255, 255, 255, 0.2);
            display: flex;
            align-items: center;
            gap: 20px;
            white-space: nowrap;
            transition: color 0.3s ease;
        }

        .icon-item:hover {
            color: var(--accent-blue);
        }

        @keyframes scrollIcons {
            0% {
                transform: translateX(0);
            }

            100% {
                transform: translateX(-50%);
            }
        }

        /* Keyboard Comparison Section */
        .keyboard-compare {
            padding: 100px 0;
            background: #000;
        }

        .comparison-container {
            position: relative;
            width: 100%;
            max-width: 1200px;
            height: 600px;
            margin: 50px auto 0;
            overflow: hidden;
            border-radius: 24px;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.8);
        }

        .comparison-item {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
        }

        .comparison-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .comparison-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 50%;
            /* Starts showing half */
            height: 100%;
            overflow: hidden;
            border-right: 4px solid white;
            z-index: 2;
        }

        .comparison-overlay .comparison-image {
            position: absolute;
            top: 0;
            left: 0;
            width: 1200px;
            /* Match container width */
            height: 100%;
            max-width: none;
        }

        .comparison-slider {
            position: absolute;
            top: 0;
            left: 50%;
            width: 4px;
            height: 100%;
            background: white;
            cursor: ew-resize;
            z-index: 10;
            transform: translateX(-50%);
        }

        .slider-handle {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            color: black;
            font-size: 1.2rem;
            box-shadow: 0 0 30px rgba(255, 255, 255, 0.4);
            pointer-events: none;
        }

        @media (max-width: 968px) {
            .wide-categories-grid {
                grid-template-columns: 1fr 1fr;
            }

            .split-section,
            .split-section.reverse {
                flex-direction: column;
            }

            .comparison-container {
                height: 400px;
            }
        }

        @media (max-width: 576px) {
            .wide-categories-grid {
                grid-template-columns: 1fr;
            }
        }

        /* Immersive Enhancements */
        .scanline {
            width: 100%;
            height: 100px;
            z-index: 10;
            background: linear-gradient(0deg, rgba(0, 0, 0, 0) 0%, var(--accent-blue-glow) 50%, rgba(0, 0, 0, 0) 100%);
            opacity: 0.1;
            position: absolute;
            bottom: 100%;
            pointer-events: none;
            animation: scanline 8s linear infinite;
        }

        @keyframes scanline {
            0% {
                bottom: 100%;
            }

            100% {
                bottom: -100px;
            }
        }

        .hero-vignette {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle, transparent 20%, #000 100%);
            z-index: 2;
            pointer-events: none;
        }

        /* Bento Grid Style */
        .bento-grid {
            display: grid;
            grid-template-areas:
                "main main side1"
                "main main side2"
                "bottom bottom bottom";
            grid-template-columns: 1fr 1fr 1fr;
            grid-template-rows: 250px 250px auto;
            gap: 25px;
            margin-top: 50px;
        }

        .bento-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 24px;
            overflow: hidden;
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 30px;
            transition: var(--transition);
        }

        .bento-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            position: absolute;
            top: 0;
            left: 0;
            z-index: 0;
            opacity: 0.7;
            transition: var(--transition);
        }

        .bento-card:hover img {
            transform: scale(1.1);
            opacity: 0.4;
        }

        .bento-content {
            position: relative;
            z-index: 2;
            text-align: center;
        }

        .bento-card h3 {
            font-size: 1.8rem;
            margin-bottom: 10px;
            text-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
        }

        .bento-card.wide {
            padding: 40px;
            align-items: flex-start;
            text-align: left;
        }

        /* Radar UI Effect */
        .tech-radar {
            width: 120px;
            height: 120px;
            border: 1px solid var(--accent-blue);
            border-radius: 50%;
            position: relative;
            background: rgba(0, 0, 0, 0.5);
            overflow: hidden;
        }

        .radar-line {
            width: 50%;
            height: 100%;
            background: linear-gradient(90deg, transparent, var(--accent-blue-glow));
            position: absolute;
            top: 0;
            left: 50%;
            transform-origin: left center;
            animation: radarRotate 3s linear infinite;
        }

        @keyframes radarRotate {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        /* Advanced Hover - Magnetic/3D feel */
        .magnetic-wrap {
            display: inline-block;
            transition: transform 0.2s cubic-bezier(0.23, 1, 0.32, 1);
        }

        @media (max-width: 968px) {
            .bento-grid {
                grid-template-areas:
                    "main main"
                    "side1 side2"
                    "bottom bottom";
                grid-template-columns: 1fr 1fr;
                grid-template-rows: auto auto auto;
            }
        }

        @keyframes sweepRefresh {
            0% {
                transform: translateX(-100%);
            }

            100% {
                transform: translateX(100%);
            }
        }

        /* Hellish Brand Animations */
        .featured-brands-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 40px;
            align-items: center;
        }

        .brand-item {
            width: 100%;
            filter: grayscale(100%);
            opacity: 0.5;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            cursor: pointer;
        }

        .brand-item:hover {
            filter: grayscale(0%);
            opacity: 1;
            transform: scale(1.15) translateY(-10px) rotate(-2deg);
            z-index: 10;
        }

        .blue-glow:hover {
            filter: drop-shadow(0 0 20px rgba(0, 150, 255, 0.8));
        }

        .red-glow:hover {
            filter: drop-shadow(0 0 20px rgba(255, 45, 85, 0.8));
        }

        .green-glow:hover {
            filter: drop-shadow(0 0 20px rgba(0, 255, 100, 0.8));
        }

        .purple-glow:hover {
            filter: drop-shadow(0 0 20px rgba(150, 0, 255, 0.8));
        }

        .orange-glow:hover {
            filter: drop-shadow(0 0 20px rgba(255, 150, 0, 0.8));
        }

        .cyan-glow:hover {
            filter: drop-shadow(0 0 20px rgba(0, 255, 255, 0.8));
        }
    </style>
</head>

