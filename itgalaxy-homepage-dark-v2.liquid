        <div class="section-title fade-up">
            <h2>The Ecosystem</h2>
        </div>

        <div class="showcase-grid">
            <div class="showcase-card fade-up">
                <div class="showcase-img">
                    <img src="https://images.unsplash.com/photo-1587829741301-dc798b83add3?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80"
                        alt="Keyboards">
                </div>
                <h3>Pro Keyboards</h3>
            </div>

            <div class="showcase-card fade-up" style="transition-delay: 0.1s;">
                <div class="showcase-img">
                    <img src="https://images.unsplash.com/photo-1598550476439-6847785fcea6?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80"
                        alt="Audio">
                </div>
                <h3>Studio Audio</h3>
            </div>

            <div class="showcase-card fade-up" style="transition-delay: 0.2s;">
                <div class="showcase-img">
                    <img src="https://images.unsplash.com/photo-1555680202-c86f0e12f086?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80"
                        alt="Components">
                </div>
                <h3>PC Components</h3>
            </div>

            <div class="showcase-card fade-up" style="transition-delay: 0.3s;">
                <div class="showcase-img">
                    <img src="https://images.unsplash.com/photo-1625842268584-8f3296236761?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80"
                        alt="Mice">
                </div>
                <h3>Precision Mice</h3>
            </div>
        </div>
    </section>

    <!-- Structured Product Grid (TPSTech Style) -->
    <section class="section-py container" style="padding-top: 0;">
        <div class="section-title fade-up"
            style="display: flex; justify-content: space-between; align-items: flex-end;">
            <h2 style="margin: 0;">New Arrivals</h2>
            <a href="#" style="color: var(--neon-blue); font-family: 'Outfit'; font-weight: 600;">View All Inventory
                &rarr;</a>
        </div>

        <div class="product-grid">
            <!-- P1 -->
            <div class="prod-card fade-up">
                <span class="prod-badge">Save 30%</span>
                <div class="prod-img">
                    <img src="https://images.unsplash.com/photo-1591405351990-4726e331f141?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80"
                        alt="Controller">
                </div>
                <div class="prod-info">
                    <h4>Elite Wireless Pro Controller (Carbon)</h4>
                    <div class="prod-price">₹4,499</div>
                    <button class="add-to-cart">Add to Cart</button>
                </div>
            </div>

            <!-- P2 -->
            <div class="prod-card fade-up">
                <div class="prod-img">
                    <img src="https://images.unsplash.com/photo-1563203369-26f2e4a5ccf7?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80"
