            </div>
            <div class="hero-img fade-up">
                <!-- Gamer Tech Image -->
                <img src="https://images.unsplash.com/photo-1618366712010-f4ae9c647dcb?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
