            </div>
            <div>
                <a href="#">Support 24/7</a> | <a href="#">Track Order</a>
            </div>
        </div>
    </div>

    <!-- Header -->
    <header>
        <div class="container nav-wrapper">
            <a href="#" class="logo">IT GALAXY</a>

            <!-- Fifine AI Search -->
            <div class="search-container">
                <i class="fa-solid fa-sparkles search-icon"></i>
