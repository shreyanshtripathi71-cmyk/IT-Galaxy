            </div>

            <!-- P3 -->
            <div class="prod-card fade-up">
                <span class="prod-badge"
                    style="background: rgba(14,165,233,0.1); color: var(--neon-blue); border-color: var(--neon-blue);">Just
                    In</span>
                <div class="prod-img">
                    <img src="https://images.unsplash.com/photo-1588702547923-7093a6c3ba33?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80"
