<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IT Galaxy | Modern Minimalist</title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
        rel="stylesheet">
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        /* Modern Light Theme Variables (TheITGear Inspired) */
        :root {
            --bg-base: #f8fafc;
            --bg-surface: #ffffff;
            --text-primary: #0f172a;
            --text-secondary: #64748b;

            /* Pastel Accents */
            --accent-purple: #8b5cf6;
            --accent-blue: #3b82f6;
            --accent-teal: #14b8a6;

            --grad-primary: linear-gradient(135deg, var(--accent-purple), var(--accent-blue));
            --grad-pastel: linear-gradient(135deg, #e0e7ff, #fae8ff);

            --glass-bg: rgba(255, 255, 255, 0.7);
            --glass-border: rgba(255, 255, 255, 0.5);
            --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.05);
            --shadow-md: 0 10px 25px rgba(0, 0, 0, 0.05);
            --shadow-hover: 0 20px 40px rgba(59, 130, 246, 0.15);

            --transition-smooth: 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-base);
            color: var(--text-primary);
            overflow-x: hidden;
            line-height: 1.6;
        }

        h1,
        h2,
        h3,
        h4 {
            font-weight: 800;
            letter-spacing: -0.5px;
        }

        a {
            color: inherit;
            text-decoration: none;
            transition: var(--transition-smooth);
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 4%;
        }

        .section-py {
            padding: 90px 0;
        }

        /* Banner (TPSTech Style) */
        .promo-banner {
            background: var(--grad-primary);
            color: white;
            text-align: center;
            padding: 10px 0;
            font-weight: 600;
            font-size: 0.9rem;
            letter-spacing: 0.5px;
        }

        /* Header (Frosted Glass) */
        header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--glass-border);
            box-shadow: var(--shadow-sm);
        }

        .nav-wrapper {
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 80px;
        }

        .logo {
            font-size: 1.8rem;
            font-weight: 800;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .logo i {
            color: var(--accent-blue);
        }

        .nav-links {
            display: flex;
            gap: 35px;
            font-weight: 600;
            color: var(--text-secondary);
        }

        .nav-links a:hover {
            color: var(--accent-purple);
        }

        .nav-actions {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .icon-btn {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background: var(--bg-surface);
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: var(--shadow-sm);
            color: var(--text-primary);
            transition: var(--transition-smooth);
            cursor: pointer;
        }

        .icon-btn:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-md);
            color: var(--accent-blue);
        }

        /* Hero Section (TheITGear Split Design) */
        .hero {
            padding: 60px 0;
            position: relative;
        }

        .hero-banner {
            background: var(--grad-pastel);
            border-radius: 30px;
            padding: 60px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 50px;
            align-items: center;
            box-shadow: var(--shadow-md);
            border: 1px solid white;
            position: relative;
            overflow: hidden;
        }

        .hero-banner::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 50vw;
            height: 50vw;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.8) 0%, transparent 60%);
            border-radius: 50%;
            z-index: 0;
        }

        .hero-text {
            position: relative;
            z-index: 1;
        }

        .tag-pill {
            display: inline-block;
            padding: 8px 16px;
            background: white;
            color: var(--accent-purple);
            border-radius: 30px;
            font-size: 0.85rem;
            font-weight: 700;
            margin-bottom: 20px;
            box-shadow: var(--shadow-sm);
        }

        .hero-text h1 {
            font-size: 3.5rem;
            line-height: 1.1;
            margin-bottom: 20px;
            color: var(--text-primary);
        }

        .hero-text p {
            font-size: 1.1rem;
            color: var(--text-secondary);
            margin-bottom: 35px;
            max-width: 450px;
        }

        .btn-gradient {
            display: inline-block;
            padding: 16px 40px;
            background: var(--grad-primary);
            color: white;
            border-radius: 12px;
            font-weight: 700;
            box-shadow: 0 10px 20px rgba(139, 92, 246, 0.3);
        }

        .btn-gradient:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(139, 92, 246, 0.4);
        }

        .hero-image {
            position: relative;
            z-index: 1;
            text-align: center;
        }

        .hero-image img {
            max-width: 100%;
            filter: drop-shadow(0 30px 40px rgba(0, 0, 0, 0.15));
            animation: float 6s ease-in-out infinite;
        }

        /* Pastel Category Grid (TheITGear Style) */
        .section-header {
            text-align: center;
            margin-bottom: 50px;
        }

        .section-header h2 {
            font-size: 2.2rem;
            margin-bottom: 10px;
        }

        .section-header p {
            color: var(--text-secondary);
        }

        .category-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 25px;
        }

        .cat-card-pastel {
            background: var(--bg-surface);
            border-radius: 20px;
            padding: 30px;
            text-align: center;
            box-shadow: var(--shadow-md);
            border: 1px solid white;
            transition: var(--transition-smooth);
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }

        /* Pastel Backgrounds per card */
        .bg-p1 {
            background: linear-gradient(to bottom right, #fdf4ff, #fae8ff);
        }

        .bg-p2 {
            background: linear-gradient(to bottom right, #f0fdfa, #ccfbf1);
        }

        .bg-p3 {
            background: linear-gradient(to bottom right, #eff6ff, #dbeafe);
        }

        .bg-p4 {
            background: linear-gradient(to bottom right, #fef2f2, #fee2e2);
        }

        .cat-card-pastel:hover {
            transform: translateY(-8px);
            box-shadow: var(--shadow-hover);
        }

        .cat-img {
            height: 140px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .cat-img img {
            max-height: 100%;
            max-width: 100%;
            object-fit: contain;
            transition: transform 0.5s;
            filter: drop-shadow(0 10px 15px rgba(0, 0, 0, 0.1));
        }

        .cat-card-pastel:hover .cat-img img {
            transform: scale(1.1);
        }

        .cat-card-pastel h3 {
            font-size: 1.2rem;
            color: var(--text-primary);
        }

        /* Clean Product Grid (TPSTech Style) */
        .product-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 30px;
        }

        .prod-minimal {
            background: var(--bg-surface);
            border-radius: 16px;
            padding: 20px;
            transition: var(--transition-smooth);
            position: relative;
            border: 1px solid rgba(0, 0, 0, 0.03);
            display: flex;
            flex-direction: column;
            group: hover;
        }

        .prod-minimal:hover {
            box-shadow: var(--shadow-hover);
            transform: translateY(-5px);
            border-color: rgba(59, 130, 246, 0.2);
        }

        .wishlist-btn {
            position: absolute;
            top: 20px;
            right: 20px;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            background: var(--bg-base);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-secondary);
            z-index: 2;
            cursor: pointer;
            transition: var(--transition-smooth);
        }

        .wishlist-btn:hover {
            color: var(--accent-purple);
            background: #f5f3ff;
        }

        .prod-img-min {
            height: 200px;
            padding: 20px;
            background: var(--bg-base);
            border-radius: 12px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .prod-img-min img {
            max-height: 100%;
            max-width: 100%;
            object-fit: contain;
            transition: transform 0.4s;
            mix-blend-mode: multiply;
            /* Removes white backgrounds from product shots */
        }

        .prod-minimal:hover .prod-img-min img {
            transform: scale(1.08);
        }

        .prod-brand {
            font-size: 0.8rem;
            color: var(--text-secondary);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

        .prod-title {
            font-size: 1.05rem;
            font-weight: 600;
            margin-bottom: 15px;
            line-height: 1.4;
            color: var(--text-primary);
        }

        .prod-bottom {
            margin-top: auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .prod-price {
            font-size: 1.3rem;
            font-weight: 800;
            color: var(--text-primary);
        }

        .add-btn {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: var(--text-primary);
            color: white;
            border: none;
            cursor: pointer;
            transition: var(--transition-smooth);
        }

        .prod-minimal:hover .add-btn {
            background: var(--grad-primary);
        }

        /* Floating Widgets (TheITGear) */
        .floater {
            position: fixed;
            bottom: 30px;
            right: 30px;
            display: flex;
            flex-direction: column;
            gap: 15px;
            z-index: 999;
        }

        .float-btn {
            width: 55px;
            height: 55px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: white;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
            cursor: pointer;
            transition: transform 0.3s;
        }

        .float-btn:hover {
            transform: scale(1.1);
        }

        .float-wa {
            background: #25D366;
        }

        /* Animations */
        @keyframes float {

            0%,
            100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-15px);
            }
        }

        .fade-up {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .fade-up.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .hero-banner {
                grid-template-columns: 1fr;
                text-align: center;
                padding: 40px 20px;
            }

            .hero-text p {
                margin: 0 auto 30px;
            }

            .category-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .product-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .nav-links {
                display: none;
            }
        }

        @media (max-width: 600px) {
            .category-grid {
                grid-template-columns: 1fr;
            }

            .product-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>

    <div class="promo-banner">
        Enjoy free express shipping on all orders over ₹5,000! 🚀
    </div>

    <header>
        <div class="container nav-wrapper">
            <a href="#" class="logo">
                <i class="fa-solid fa-shapes"></i> IT Galaxy
            </a>

            <div class="nav-links">
                <a href="#">Shop All</a>
                <a href="#">Laptops</a>
                <a href="#">Components</a>
                <a href="#">Accessories</a>
            </div>

            <div class="nav-actions">
                <div class="icon-btn" title="Search"><i class="fa-solid fa-magnifying-glass"></i></div>
                <div class="icon-btn" title="Account"><i class="fa-regular fa-user"></i></div>
                <div class="icon-btn" title="Cart"><i class="fa-solid fa-cart-shopping"></i></div>
            </div>
        </div>
    </header>

    <!-- TheITGear Style Hero -->
    <section class="hero container">
        <div class="hero-banner fade-up">
            <div class="hero-text">
                <span class="tag-pill">New Generation Tech</span>
                <h1>Upgrade Your <br>Workspace Today</h1>
                <p>Discover minimal, high-performance setups designed for creators, developers, and professionals.</p>
                <a href="#" class="btn-gradient">Shop Collections</a>
            </div>
            <div class="hero-image">
                <img src="https://images.unsplash.com/photo-1593640408182-31c70c8268f5?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                    alt="Minimal Laptop Setup" style="border-radius: 20px;">
            </div>
        </div>
    </section>

    <!-- TheITGear Pastel Category Cards -->
    <section class="section-py container">
        <div class="section-header fade-up">
            <h2>Shop by Category</h2>
            <p>Everything you need for the perfect setup</p>
        </div>

        <div class="category-grid">
            <div class="cat-card-pastel bg-p1 fade-up">
                <div class="cat-img">
                    <img src="https://images.unsplash.com/photo-1587829741301-dc798b83add3?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80"
                        alt="Keyboards">
                </div>
                <h3>Mechanical Keyboards</h3>
            </div>

            <div class="cat-card-pastel bg-p2 fade-up" style="transition-delay: 0.1s;">
                <div class="cat-img">
                    <img src="https://images.unsplash.com/photo-1588702547923-7093a6c3ba33?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80"
                        alt="Laptops">
                </div>
                <h3>Pro Laptops</h3>
            </div>

            <div class="cat-card-pastel bg-p3 fade-up" style="transition-delay: 0.2s;">
                <div class="cat-img">
                    <img src="https://images.unsplash.com/photo-1625842268584-8f3296236761?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80"
                        alt="Mice">
                </div>
                <h3>Ergonomic Mice</h3>
            </div>

            <div class="cat-card-pastel bg-p4 fade-up" style="transition-delay: 0.3s;">
                <div class="cat-img">
                    <img src="https://images.unsplash.com/photo-1598550476439-6847785fcea6?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80"
                        alt="Audio">
                </div>
                <h3>Studio Audio</h3>
            </div>
        </div>
    </section>

    <!-- TPSTech Style Clean Product Grid -->
    <section class="section-py container" style="padding-top: 0;">
        <div class="section-header fade-up"
            style="display: flex; justify-content: space-between; align-items: flex-end;">
            <div style="text-align: left;">
                <h2 style="margin-bottom: 5px;">Trending Hardware</h2>
                <p>Top picks for the modern professional</p>
            </div>
            <a href="#" style="color: var(--accent-blue); font-weight: 700;">Explore All <i
                    class="fa-solid fa-arrow-right"></i></a>
        </div>

        <div class="product-grid">
            <!-- Item 1 -->
            <div class="prod-minimal fade-up">
                <div class="wishlist-btn"><i class="fa-solid fa-heart"></i></div>
                <div class="prod-img-min">
                    <img src="https://images.unsplash.com/photo-1618366712010-f4ae9c647dcb?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80"
                        alt="Headphones">
                </div>
                <div class="prod-brand">SONY</div>
                <h4 class="prod-title">WH-1000XM5 Noise Cancelling Headphones</h4>
                <div class="prod-bottom">
                    <div class="prod-price">₹29,990</div>
                    <button class="add-btn"><i class="fa-solid fa-plus"></i></button>
                </div>
            </div>

            <!-- Item 2 -->
            <div class="prod-minimal fade-up">
                <div class="wishlist-btn"><i class="fa-regular fa-heart"></i></div>
                <div class="prod-img-min">
                    <img src="https://images.unsplash.com/photo-1563203369-26f2e4a5ccf7?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80"
                        alt="SSD">
                </div>
                <div class="prod-brand">SAMSUNG</div>
                <h4 class="prod-title">990 PRO 2TB PCIe 4.0 NVMe SSD</h4>
                <div class="prod-bottom">
                    <div class="prod-price">₹18,500</div>
                    <button class="add-btn"><i class="fa-solid fa-plus"></i></button>
                </div>
            </div>

            <!-- Item 3 -->
            <div class="prod-minimal fade-up">
                <div class="wishlist-btn"><i class="fa-regular fa-heart"></i></div>
                <div class="prod-img-min">
                    <img src="https://images.unsplash.com/photo-1591405351990-4726e331f141?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80"
                        alt="Controller">
                </div>
                <div class="prod-brand">MICROSOFT</div>
                <h4 class="prod-title">Xbox Elite Wireless Controller Series 2</h4>
                <div class="prod-bottom">
                    <div class="prod-price">₹4,499</div>
                    <button class="add-btn"><i class="fa-solid fa-plus"></i></button>
                </div>
            </div>

            <!-- Item 4 -->
            <div class="prod-minimal fade-up">
                <div class="wishlist-btn"><i class="fa-regular fa-heart"></i></div>
                <div class="prod-img-min">
                    <img src="https://images.unsplash.com/photo-1555680202-c86f0e12f086?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80"
                        alt="Motherboard">
                </div>
                <div class="prod-brand">ASUS ROG</div>
                <h4 class="prod-title">Maximus Z790 Hero Motherboard</h4>
                <div class="prod-bottom">
                    <div class="prod-price">₹65,000</div>
                    <button class="add-btn"><i class="fa-solid fa-plus"></i></button>
                </div>
            </div>
        </div>
    </section>

    <!-- TheITGear Floating Widget -->
    <div class="floater">
        <a href="https://wa.me/" class="float-btn float-wa" title="WhatsApp Us">
            <i class="fa-brands fa-whatsapp"></i>
        </a>
    </div>

    <script>
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
    </script>
</body>

</html>