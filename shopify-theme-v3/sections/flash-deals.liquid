{%- comment -%}
  Flash Deals Section — Countdown timer + deal cards
{%- endcomment -%}

<section class="flash-deals-section animate-on-scroll">
  <div class="container">
    <div class="flash-deals-header">
      <div>
        <h2 style="font-size: 2.5rem; margin-bottom: 8px;">
          <span class="text-gradient">{{ section.settings.heading_highlight | default: 'Flash Deals' }}</span>
          {{ section.settings.heading_suffix | default: 'Exclusive' }}
        </h2>
        <p style="color: var(--text-muted); font-size: 1rem;">
          {{ section.settings.subtext | default: 'Limited quantity offers on pro hardware' }}
        </p>
      </div>
      <div class="countdown-timer">
        <div class="countdown-item">
          <span class="countdown-val">{{ section.settings.hours | default: '08' }}</span>
          <span class="countdown-label">Hrs</span>
        </div>
        <div class="countdown-item">
          <span class="countdown-val">{{ section.settings.minutes | default: '42' }}</span>
          <span class="countdown-label">Min</span>
        </div>
        <div class="countdown-item">
          <span class="countdown-val">{{ section.settings.seconds | default: '15' }}</span>
          <span class="countdown-label">Sec</span>
        </div>
      </div>
    </div>

    <div class="product-scroller-wrapper animate-on-scroll" style="margin-top: 20px">
      <button class="scroll-btn scroll-left" onclick="scrollSection('flashScroller', -1)" aria-label="Scroll left">
        <i class="fa-solid fa-chevron-left"></i>
      </button>

      <div class="product-scroller" id="flashScroller">
        {%- if section.settings.collection != blank -%}
          {%- for product in collections[section.settings.collection].products limit: section.settings.max_products -%}
            {%- assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
            {% render 'product-card',
              card_class: 'flash-card',
              product_image: product.featured_image | image_url: width: 400,
              product_title: product.title,
              product_category: product.type,
              product_price: product.price | money,
              compare_price: product.compare_at_price | money,
              badge_text: discount | append: '% OFF',
              badge_type: 'flash',
              hide_actions: true
            %}
          {%- endfor -%}
        {%- elsif section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'deal' -%}
              {% render 'product-card',
                card_class: 'flash-card',
                product_image: block.settings.image | image_url: width: 400 | default: block.settings.image_url,
                product_title: block.settings.title,
                product_category: block.settings.category,
                product_price: block.settings.price,
                compare_price: block.settings.compare_price,
                badge_text: block.settings.badge,
                badge_type: 'flash',
                hide_actions: true
              %}
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          <!-- Sample flash deals shown when no collection/blocks are set -->
          {% render 'product-card', card_class: 'flash-card', product_image: 'https://images.unsplash.com/photo-1597872200370-496de2c1a82b?auto=format&fit=crop&w=400&q=80', product_title: 'AMD Ryzen 9 7950X Processor', product_category: 'Processors', product_price: '₹52,499', compare_price: '₹68,000', badge_text: '-35%', badge_type: 'flash' %}
          {% render 'product-card', card_class: 'flash-card', product_image: 'https://images.unsplash.com/photo-1591488320449-011701bb6704?auto=format&fit=crop&w=400&q=80', product_title: 'GeForce RTX 4090 24GB OC', product_category: 'Graphics Cards', product_price: '₹1,45,999', compare_price: '₹1,89,999', badge_text: '-23%', badge_type: 'flash' %}
          {% render 'product-card', card_class: 'flash-card', product_image: 'https://images.unsplash.com/photo-1527443154391-507e9dc6c5cc?auto=format&fit=crop&w=400&q=80', product_title: '34" Ultrawide QHD 144Hz Curved', product_category: 'Monitors', product_price: '₹38,999', compare_price: '₹54,999', badge_text: '-29%', badge_type: 'flash' %}
          {% render 'product-card', card_class: 'flash-card', product_image: 'https://images.unsplash.com/photo-1587831990711-23ca6441447b?auto=format&fit=crop&w=400&q=80', product_title: 'ROG Maximus Z790 Hero', product_category: 'Motherboards', product_price: '₹42,999', compare_price: '₹55,000', badge_text: '-22%', badge_type: 'flash' %}
          {% render 'product-card', card_class: 'flash-card', product_image: 'https://images.unsplash.com/photo-1626218174358-7769486c4b79?auto=format&fit=crop&w=400&q=80', product_title: '64GB DDR5 5600MHz Kit', product_category: 'Memory', product_price: '₹18,999', compare_price: '₹24,999', badge_text: '-24%', badge_type: 'flash' %}
          {% render 'product-card', card_class: 'flash-card', product_image: 'https://images.unsplash.com/photo-1587829741301-dc798b83add3?auto=format&fit=crop&w=400&q=80', product_title: 'Custom Mechanical Keyboard 75%', product_category: 'Peripherals', product_price: '₹7,999', compare_price: '₹11,999', badge_text: '-33%', badge_type: 'flash' %}
          {% render 'product-card', card_class: 'flash-card', product_image: 'https://images.unsplash.com/photo-1618366712010-f4ae9c647dcb?auto=format&fit=crop&w=400&q=80', product_title: 'Audiophile Planar Magnetic Cans', product_category: 'Audio', product_price: '₹11,499', compare_price: '₹16,999', badge_text: '-32%', badge_type: 'flash' %}
          {% render 'product-card', card_class: 'flash-card', product_image: 'https://images.unsplash.com/photo-1544197150-b99a580bb7a8?auto=format&fit=crop&w=400&q=80', product_title: 'Wi-Fi 7 Mesh Router System', product_category: 'Networking', product_price: '₹22,999', compare_price: '₹32,000', badge_text: '-28%', badge_type: 'flash' %}
        {%- endif -%}
      </div>

      <button class="scroll-btn scroll-right" onclick="scrollSection('flashScroller', 1)" aria-label="Scroll right">
        <i class="fa-solid fa-chevron-right"></i>
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Flash Deals",
  "settings": [
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading Highlight",
      "default": "Flash Deals"
    },
    {
      "type": "text",
      "id": "heading_suffix",
      "label": "Heading Suffix",
      "default": "Exclusive"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Limited quantity offers on pro hardware"
    },
    {
      "type": "text",
      "id": "hours",
      "label": "Timer Hours",
      "default": "08"
    },
    {
      "type": "text",
      "id": "minutes",
      "label": "Timer Minutes",
      "default": "42"
    },
    {
      "type": "text",
      "id": "seconds",
      "label": "Timer Seconds",
      "default": "15"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Shopify Collection (optional)"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max Products",
      "min": 4,
      "max": 20,
      "step": 1,
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "deal",
      "name": "Deal Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product Image"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Image URL (fallback)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Product Title",
          "default": "Deal Product"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Category",
          "default": "Components"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Sale Price",
          "default": "₹52,499"
        },
        {
          "type": "text",
          "id": "compare_price",
          "label": "Original Price",
          "default": "₹68,000"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge Text",
          "default": "-35%"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Flash Deals",
      "blocks": []
    }
  ]
}
{% endschema %}
