{%- comment -%}
  Floating WhatsApp Widget
{%- endcomment -%}

{%- if section.settings.whatsapp_number != blank -%}
  <a href="https://wa.me/{{ section.settings.whatsapp_number }}"
    target="_blank"
    class="floating-whatsapp"
    aria-label="Chat with us on WhatsApp">
    <i class="fa-brands fa-whatsapp"></i>
    <span class="whatsapp-tooltip">{{ section.settings.tooltip_text | default: 'Chat with a Build Expert' }}</span>
  </a>
{%- endif -%}

{% schema %}
{
  "name": "WhatsApp Widget",
  "settings": [
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "WhatsApp Number (with country code)",
      "default": "919876543210",
      "info": "No + or spaces, e.g. 919876543210"
    },
    {
      "type": "text",
      "id": "tooltip_text",
      "label": "Tooltip Text",
      "default": "Chat with a Build Expert"
    }
  ]
}
{% endschema %}
