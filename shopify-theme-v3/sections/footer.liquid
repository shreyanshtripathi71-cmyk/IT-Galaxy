{%- comment -%}
  Footer — Site footer with links, newsletter, social, legal, payments
{%- endcomment -%}

<footer class="site-footer" style="position:relative;overflow:hidden;padding-top:80px;background:#05020a;border-top:1px solid rgba(255,255,255,0.05);">
  <div class="container" style="position: relative; z-index: 2">
    <div class="footer-grid">
      <!-- About Column -->
      <div class="footer-about">
        <a href="/" class="logo" style="font-size:1.8rem;margin-bottom:20px;display:inline-block;">
          <i class="{{ section.settings.logo_icon | default: 'fa-solid fa-microchip' }}" style="color:var(--accent)"></i>
          {{ section.settings.store_name | default: shop.name }}
        </a>
        <p style="color:var(--text-muted);line-height:1.6;margin-bottom:25px;">
          {{ section.settings.about_text | default: 'Your premium destination for high-end electronics, elite gaming gear, and professional PC components.' }}
        </p>
        <div class="social-icons">
          {%- if settings.social_instagram != blank -%}
            <a href="{{ settings.social_instagram }}" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
          {%- endif -%}
          {%- if settings.social_facebook != blank -%}
            <a href="{{ settings.social_facebook }}" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
          {%- endif -%}
          {%- if settings.social_twitter != blank -%}
            <a href="{{ settings.social_twitter }}" aria-label="Twitter"><i class="fa-brands fa-twitter"></i></a>
          {%- endif -%}
          {%- if settings.social_youtube != blank -%}
            <a href="{{ settings.social_youtube }}" aria-label="YouTube"><i class="fa-brands fa-youtube"></i></a>
          {%- endif -%}
        </div>
      </div>

      <!-- Link Columns -->
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_column' -%}
          <div class="footer-links" {{ block.shopify_attributes }}>
            <h4>{{ block.settings.heading }}</h4>
            {%- if block.settings.menu != blank -%}
              <ul>
                {%- for link in linklists[block.settings.menu].links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- else -%}
              {%- assign links = block.settings.links_text | split: '|' -%}
              <ul>
                {%- for link_text in links -%}
                  <li><a href="#">{{ link_text }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if block.type == 'newsletter' -%}
          <div class="newsletter" {{ block.shopify_attributes }}>
            <h4>{{ block.settings.heading | default: 'Galaxy Insider' }}</h4>
            <p style="color:var(--text-muted);margin-bottom:20px;font-size:0.95rem;line-height:1.5;">
              {{ block.settings.description | default: 'Join the elite. Subscribe for exclusive hardware drops and the latest tech news.' }}
            </p>
            {%- form 'customer', id: 'footer-newsletter' -%}
              <div style="display:flex;flex-direction:column;gap:10px;">
                <input type="email" name="contact[email]" placeholder="{{ block.settings.placeholder | default: 'Enter your email address' }}" required />
                <button type="submit" class="btn btn-primary" style="width:100%;padding:12px;border-radius:8px;font-weight:600;">
                  {{ block.settings.btn_text | default: 'Subscribe' }}
                </button>
              </div>
            {%- endform -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Footer Bottom -->
    <div class="footer-bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.copyright_text | default: 'Constructed for the future.' }}</p>

      <div class="footer-legal-links">
        {%- if section.settings.privacy_link != blank -%}
          <a href="{{ section.settings.privacy_link }}">Privacy Policy</a>
        {%- endif -%}
        {%- if section.settings.terms_link != blank -%}
          <a href="{{ section.settings.terms_link }}">Terms of Service</a>
        {%- endif -%}
        {%- if section.settings.refund_link != blank -%}
          <a href="{{ section.settings.refund_link }}">Return Policy</a>
        {%- endif -%}
      </div>

      <div class="payment-icons">
        <i class="fa-brands fa-cc-visa"></i>
        <i class="fa-brands fa-cc-mastercard"></i>
        <i class="fa-brands fa-cc-paypal"></i>
        <i class="fa-brands fa-google-pay"></i>
        <i class="fa-brands fa-apple-pay"></i>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "store_name",
      "label": "Store Name",
      "default": "IT Galaxy"
    },
    {
      "type": "text",
      "id": "logo_icon",
      "label": "Logo Icon Class",
      "default": "fa-solid fa-microchip"
    },
    {
      "type": "textarea",
      "id": "about_text",
      "label": "About Text",
      "default": "Your premium destination for high-end electronics, elite gaming gear, and professional PC components. We deliver uncompromising performance directly to your doorstep."
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "Constructed for the future."
    },
    {
      "type": "url",
      "id": "privacy_link",
      "label": "Privacy Policy Link"
    },
    {
      "type": "url",
      "id": "terms_link",
      "label": "Terms of Service Link"
    },
    {
      "type": "url",
      "id": "refund_link",
      "label": "Return Policy Link"
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Link Column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column Heading",
          "default": "Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Shopify Menu (optional)"
        },
        {
          "type": "text",
          "id": "links_text",
          "label": "Manual Links (pipe-separated, fallback)",
          "info": "e.g. Processors|Graphics Cards|Motherboards|Memory"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Galaxy Insider"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Join the elite. Subscribe for exclusive hardware drops, early access deals, and the latest tech news."
        },
        {
          "type": "text",
          "id": "placeholder",
          "label": "Input Placeholder",
          "default": "Enter your email address"
        },
        {
          "type": "text",
          "id": "btn_text",
          "label": "Button Text",
          "default": "Subscribe"
        }
      ]
    }
  ]
}
{% endschema %}
