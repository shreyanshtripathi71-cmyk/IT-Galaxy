{%- comment -%} Cart Page Section {%- endcomment -%}

<div class="container section-padding" style="max-width:900px;">
  <h1 style="font-size:2.5rem;margin-bottom:40px;">Your Cart</h1>

  {%- if cart.item_count > 0 -%}
    <form action="/cart" method="post">
      {%- for item in cart.items -%}
        <div style="display:flex;align-items:center;gap:20px;padding:20px 0;border-bottom:1px solid var(--border-color);">
          <div style="width:80px;height:80px;background:#0a0a0a;border-radius:4px;overflow:hidden;flex-shrink:0;">
            <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title | escape }}" style="width:100%;height:100%;object-fit:contain;" />
          </div>
          <div style="flex:1;">
            <a href="{{ item.url }}" style="font-weight:600;color:white;">{{ item.title }}</a>
            {%- unless item.variant.title == 'Default Title' -%}
              <p style="color:var(--text-muted);font-size:0.85rem;">{{ item.variant.title }}</p>
            {%- endunless -%}
          </div>
          <div style="display:flex;align-items:center;gap:10px;">
            <input type="number" name="updates[]" value="{{ item.quantity }}" min="0"
              style="width:60px;padding:8px;background:#111;border:1px solid var(--border-color);color:white;border-radius:4px;text-align:center;font-family:inherit;" />
          </div>
          <div style="text-align:right;min-width:100px;">
            <span style="font-weight:700;font-size:1.1rem;">{{ item.line_price | money }}</span>
          </div>
        </div>
      {%- endfor -%}

      <div style="display:flex;justify-content:space-between;align-items:center;margin-top:30px;padding-top:20px;border-top:1px solid var(--border-color);">
        <div>
          <p style="font-size:1.3rem;font-weight:700;">Total: {{ cart.total_price | money }}</p>
          <p style="color:var(--text-muted);font-size:0.85rem;">Shipping calculated at checkout</p>
        </div>
        <div style="display:flex;gap:12px;">
          <button type="submit" name="update" class="btn btn-outline">Update Cart</button>
          <button type="submit" name="checkout" class="btn btn-primary">Checkout</button>
        </div>
      </div>
    </form>
  {%- else -%}
    <div style="text-align:center;padding:80px 0;">
      <i class="fa-solid fa-cart-shopping" style="font-size:4rem;color:var(--text-muted);margin-bottom:20px;display:block;"></i>
      <p style="color:var(--text-muted);margin-bottom:30px;">Your cart is empty</p>
      <a href="/collections/all" class="btn btn-primary">Continue Shopping</a>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Cart Page",
  "settings": []
}
{% endschema %}
