{%- comment -%}
  Elite Collection — 4-Tab Product Showcase System
{%- endcomment -%}

<section class="section-padding animate-on-scroll" style="padding-top: 60px">
  <div class="container">
    <div class="section-header" style="text-align:center;max-width:800px;margin:0 auto 50px">
      <h2 class="section-title">
        {{ section.settings.heading_prefix | default: 'Curate Your' }}
        <span class="text-gradient">{{ section.settings.heading_highlight | default: 'Ecosystem' }}</span>
      </h2>
      <p style="color:var(--text-muted)">{{ section.settings.subtext }}</p>
    </div>

    <!-- Tab Navigation -->
    <div class="elite-tabs" style="display:flex;justify-content:center;gap:15px;margin-bottom:40px;flex-wrap:wrap;">
      {%- for block in section.blocks -%}
        <button class="btn {% if forloop.first %}btn-primary{% else %}btn-outline{% endif %}"
          onclick="switchEliteTab('{{ block.settings.tab_id }}')"
          id="tab-{{ block.settings.tab_id }}"
          {{ block.shopify_attributes }}>
          {{ block.settings.tab_label }}
        </button>
      {%- endfor -%}
    </div>

    <!-- Tab Content Area -->
    <div class="split-section reverse" id="eliteContent" style="min-height:400px;align-items:center">
      {%- assign first_block = section.blocks | first -%}
      <div class="split-image" id="eliteImageContainer">
        {%- if first_block.settings.image != blank -%}
          <img src="{{ first_block.settings.image | image_url: width: 800 }}" alt="{{ first_block.settings.title }}" id="eliteImage" loading="lazy" />
        {%- endif -%}
      </div>
      <div class="split-content" id="eliteTextContainer">
        <h3 style="font-size:2rem;margin-bottom:15px">
          <span class="text-gradient" id="eliteTitle">{{ first_block.settings.title }}</span>
        </h3>
        <p style="color:var(--text-muted);margin-bottom:30px;font-size:1.1rem;" id="eliteDesc">
          {{ first_block.settings.description }}
        </p>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:40px;" id="eliteSpecs">
          <div class="product-card" style="margin:0;padding:15px;background:rgba(255,255,255,0.03);">
            <h4 style="font-size:0.9rem;color:var(--accent)">{{ first_block.settings.spec1_label }}</h4>
            <p style="font-size:1.2rem;font-weight:bold">{{ first_block.settings.spec1_value }}</p>
          </div>
          <div class="product-card" style="margin:0;padding:15px;background:rgba(255,255,255,0.03);">
            <h4 style="font-size:0.9rem;color:var(--accent)">{{ first_block.settings.spec2_label }}</h4>
            <p style="font-size:1.2rem;font-weight:bold">{{ first_block.settings.spec2_value }}</p>
          </div>
        </div>

        {%- if section.settings.btn_text != blank -%}
          <a href="{{ section.settings.btn_link | default: '#' }}" class="btn btn-primary">{{ section.settings.btn_text }}</a>
        {%- endif -%}
      </div>
    </div>

    <!-- Hidden data attributes for JS tab switching -->
    {%- for block in section.blocks -%}
      <div data-elite-tab="{{ block.settings.tab_id }}"
        data-title="{{ block.settings.title }}"
        data-desc="{{ block.settings.description | escape }}"
        data-img="{{ block.settings.image | image_url: width: 800 }}"
        data-spec1-label="{{ block.settings.spec1_label }}"
        data-spec1-val="{{ block.settings.spec1_value }}"
        data-spec2-label="{{ block.settings.spec2_label }}"
        data-spec2-val="{{ block.settings.spec2_value }}"
        style="display:none"></div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Elite Collection",
  "settings": [
    {
      "type": "text",
      "id": "heading_prefix",
      "label": "Heading Prefix",
      "default": "Curate Your"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading Highlight",
      "default": "Ecosystem"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "The most compatible, high-end peripherals hand-picked by our experts for a seamless, breathtaking workstation experience."
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "CTA Button Text",
      "default": "Shop Displays"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "CTA Button Link"
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Product Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_id",
          "label": "Tab ID (unique key)",
          "default": "monitor"
        },
        {
          "type": "text",
          "id": "tab_label",
          "label": "Tab Button Label",
          "default": "The Monitor"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Product Title",
          "default": "Pro Display XDR"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Product Description",
          "default": "A masterful 6K Retina display with extreme dynamic range, staggering contrast ratio, and a hyper-wide viewing angle."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product Image"
        },
        {
          "type": "text",
          "id": "spec1_label",
          "label": "Spec 1 Label",
          "default": "Resolution"
        },
        {
          "type": "text",
          "id": "spec1_value",
          "label": "Spec 1 Value",
          "default": "6016 x 3384"
        },
        {
          "type": "text",
          "id": "spec2_label",
          "label": "Spec 2 Label",
          "default": "Brightness"
        },
        {
          "type": "text",
          "id": "spec2_value",
          "label": "Spec 2 Value",
          "default": "1600 nits"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Elite Collection",
      "blocks": [
        {
          "type": "tab",
          "settings": {
            "tab_id": "monitor",
            "tab_label": "The Monitor",
            "title": "Pro Display XDR",
            "description": "A masterful 6K Retina display with extreme dynamic range, staggering contrast ratio, and a hyper-wide viewing angle.",
            "spec1_label": "Resolution",
            "spec1_value": "6016 x 3384",
            "spec2_label": "Brightness",
            "spec2_value": "1600 nits"
          }
        },
        {
          "type": "tab",
          "settings": {
            "tab_id": "headset",
            "tab_label": "The Headset",
            "title": "Studio ANC Wireless",
            "description": "Lossless high-fidelity audio paired with active noise cancellation.",
            "spec1_label": "Drivers",
            "spec1_value": "50mm Neodymium",
            "spec2_label": "Battery",
            "spec2_value": "40 Hours"
          }
        },
        {
          "type": "tab",
          "settings": {
            "tab_id": "webcam",
            "tab_label": "The Webcam",
            "title": "Creator Cam 4K",
            "description": "Broadcast in stunning detail with a premium glass lens and smart auto-focus.",
            "spec1_label": "Sensor",
            "spec1_value": "1/1.8\" CMOS",
            "spec2_label": "Framerate",
            "spec2_value": "4K 60fps"
          }
        },
        {
          "type": "tab",
          "settings": {
            "tab_id": "setup",
            "tab_label": "The Ultimate Setup",
            "title": "The Ultimate Ecosystem",
            "description": "Why settle for parts when you can have a symphony?",
            "spec1_label": "Optimization",
            "spec1_value": "Pre-synced",
            "spec2_label": "Lighting",
            "spec2_value": "Aura Sync"
          }
        }
      ]
    }
  ]
}
{% endschema %}
