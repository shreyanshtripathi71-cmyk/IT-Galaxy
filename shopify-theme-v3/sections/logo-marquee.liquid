{%- comment -%}
  Logo Marquee — Infinite scrolling brand logos
{%- endcomment -%}

<section class="logo-marquee-section">
  <div class="logo-marquee-track">
    <div class="logo-marquee-slide">
      {%- for block in section.blocks -%}
        {%- if block.settings.logo != blank -%}
          <img
            src="{{ block.settings.logo | image_url: height: 140 }}"
            alt="{{ block.settings.brand_name | default: 'Brand' }}"
            loading="lazy"
            {{ block.shopify_attributes }} />
        {%- endif -%}
      {%- endfor -%}
    </div>
    <!-- Duplicate for seamless loop -->
    <div class="logo-marquee-slide">
      {%- for block in section.blocks -%}
        {%- if block.settings.logo != blank -%}
          <img
            src="{{ block.settings.logo | image_url: height: 140 }}"
            alt="{{ block.settings.brand_name | default: 'Brand' }}"
            loading="lazy" />
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Logo Marquee",
  "settings": [
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll Speed (seconds)",
      "min": 10,
      "max": 60,
      "step": 5,
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "brand_logo",
      "name": "Brand Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo Image"
        },
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand Name",
          "default": "Brand"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo Marquee",
      "blocks": []
    }
  ]
}
{% endschema %}
