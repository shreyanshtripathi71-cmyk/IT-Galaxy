{%- comment -%}
  Featured Products Section — Top Selling horizontal scroller
  Uses Shopify collections when connected, falls back to blocks
{%- endcomment -%}

<section class="section-padding" style="padding-top: 80px; overflow-x: hidden">
  <div class="container">
    <div class="section-header animate-on-scroll" style="text-align:left;display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:40px;">
      <div>
        <h2 style="font-size: 2.5rem;">
          <span class="text-gradient">{{ section.settings.heading_highlight | default: 'Top Selling' }}</span>
          {{ section.settings.heading_suffix | default: 'Products' }}
        </h2>
        <p>{{ section.settings.subtext | default: 'Trending hardware loved by our customers' }}</p>
      </div>
      {%- if section.settings.view_all_link != blank -%}
        <a href="{{ section.settings.view_all_link }}" style="color:var(--accent);font-weight:600">
          View All <i class="fa-solid fa-arrow-right"></i>
        </a>
      {%- endif -%}
    </div>

    <div class="product-scroller-wrapper animate-on-scroll" style="margin-top: 20px">
      <button class="scroll-btn scroll-left" onclick="scrollSection('productScroller', -1)" aria-label="Scroll left">
        <i class="fa-solid fa-chevron-left"></i>
      </button>

      <div class="product-scroller" id="productScroller">
        {%- if section.settings.collection != blank -%}
          {%- for product in collections[section.settings.collection].products limit: section.settings.max_products -%}
            {% render 'product-card',
              product_image: product.featured_image | image_url: width: 400,
              product_title: product.title,
              product_category: product.type,
              product_price: product.price | money,
              compare_price: product.compare_at_price | money,
              product_rating: null,
              badge_text: null
            %}
          {%- endfor -%}
        {%- elsif section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'product' -%}
              {% render 'product-card',
                product_image: block.settings.image | image_url: width: 400 | default: block.settings.image_url,
                product_title: block.settings.title,
                product_category: block.settings.category,
                product_price: block.settings.price,
                compare_price: block.settings.compare_price,
                product_rating: block.settings.rating,
                badge_text: block.settings.badge,
                badge_color: block.settings.badge_color
              %}
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          <!-- Sample products shown when no collection/blocks are set -->
          {% render 'product-card', product_image: 'https://images.unsplash.com/photo-1587829741301-dc798b83add3?auto=format&fit=crop&w=400&q=80', product_title: 'Mechanical RGB Gaming Keyboard Pro', product_category: 'Peripherals', product_price: '₹8,499', compare_price: '₹12,999', product_rating: '4.8', badge_text: 'Sale' %}
          {% render 'product-card', product_image: 'https://images.unsplash.com/photo-1618366712010-f4ae9c647dcb?auto=format&fit=crop&w=400&q=80', product_title: 'Wireless Noise Cancelling Headset 7.1', product_category: 'Audio', product_price: '₹14,200', compare_price: '', product_rating: '4.9', badge_text: '' %}
          {% render 'product-card', product_image: 'https://images.unsplash.com/photo-1625842268584-8f3296236761?auto=format&fit=crop&w=400&q=80', product_title: 'Ultralight Wireless Gaming Mouse', product_category: 'Mice', product_price: '₹6,999', compare_price: '', product_rating: '4.7', badge_text: 'New', badge_color: '#44D62C' %}
          {% render 'product-card', product_image: 'https://images.unsplash.com/photo-1600003014794-cfd82e9714af?auto=format&fit=crop&w=400&q=80', product_title: 'Premium Wrist Rest & Deskpad Combo', product_category: 'Accessories', product_price: '₹4,499', compare_price: '₹5,999', product_rating: '4.6', badge_text: '' %}
          {% render 'product-card', product_image: 'https://images.unsplash.com/photo-1597872200370-496de2c1a82b?auto=format&fit=crop&w=400&q=80', product_title: 'Intel Core i9-14900K Processor', product_category: 'Components', product_price: '₹18,500', compare_price: '', product_rating: '4.9', badge_text: '' %}
          {% render 'product-card', product_image: 'https://images.unsplash.com/photo-1527443154391-507e9dc6c5cc?auto=format&fit=crop&w=400&q=80', product_title: '27" 1440p 165Hz IPS Gaming Monitor', product_category: 'Monitors', product_price: '₹28,999', compare_price: '', product_rating: '4.8', badge_text: '' %}
          {% render 'product-card', product_image: 'https://images.unsplash.com/photo-1587831990711-23ca6441447b?auto=format&fit=crop&w=400&q=80', product_title: 'Z790 Elite AX DDR5 Motherboard', product_category: 'Components', product_price: '₹24,500', compare_price: '', product_rating: '4.7', badge_text: '' %}
          {% render 'product-card', product_image: 'https://images.unsplash.com/photo-1626218174358-7769486c4b79?auto=format&fit=crop&w=400&q=80', product_title: '32GB DDR5 6000MHz RGB RAM', product_category: 'Memory', product_price: '₹12,499', compare_price: '', product_rating: '4.8', badge_text: '' %}
          {% render 'product-card', product_image: 'https://images.unsplash.com/photo-1544197150-b99a580bb7a8?auto=format&fit=crop&w=400&q=80', product_title: 'AX6000 Wi-Fi 6 Gaming Router', product_category: 'Networking', product_price: '₹16,999', compare_price: '', product_rating: '4.6', badge_text: '' %}
          {% render 'product-card', product_image: 'https://images.unsplash.com/photo-1591488320449-011701bb6704?auto=format&fit=crop&w=400&q=80', product_title: 'GeForce RTX 4080 Super 16GB', product_category: 'Graphics Cards', product_price: '₹1,15,999', compare_price: '', product_rating: '5.0', badge_text: 'Top', badge_color: '#44D62C' %}
        {%- endif -%}
      </div>

      <button class="scroll-btn scroll-right" onclick="scrollSection('productScroller', 1)" aria-label="Scroll right">
        <i class="fa-solid fa-chevron-right"></i>
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading Highlight",
      "default": "Top Selling"
    },
    {
      "type": "text",
      "id": "heading_suffix",
      "label": "Heading Suffix",
      "default": "Products"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Trending hardware loved by our customers"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All Link"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Shopify Collection (optional)"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max Products",
      "min": 4,
      "max": 20,
      "step": 1,
      "default": 10
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product Image"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Image URL (fallback)",
          "info": "Use if no image is uploaded"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Product Title",
          "default": "Product Name"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Category",
          "default": "Category"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "₹9,999"
        },
        {
          "type": "text",
          "id": "compare_price",
          "label": "Compare at Price"
        },
        {
          "type": "text",
          "id": "rating",
          "label": "Rating",
          "default": "4.8"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge Text"
        },
        {
          "type": "color",
          "id": "badge_color",
          "label": "Badge Color"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Products",
      "blocks": []
    }
  ]
}
{% endschema %}
